
{%- doc -%}
  Renders a compact share row for the product page.
  Options: WhatsApp, email, copy link, and native share (mobile).
{%- enddoc -%}

{%- assign share_url = product.url | prepend: shop.url -%}
{%- assign share_title = product.title | escape -%}

<div
  class="product-share spacing-style"
  id="product-share-{{ block.id }}"
  style="{% render 'spacing-style', settings: block.settings %}"
  {{ block.shopify_attributes }}
>
  {%- if block.settings.label != blank -%}
    <span class="product-share__label">{{ block.settings.label }}</span>
  {%- endif -%}

  <div class="product-share__buttons">

    {%- comment -%} Native share — revealed by JS when navigator.share is available {%- endcomment -%}
    <button
      class="product-share__btn product-share__native-btn"
      data-share-url="{{ share_url }}"
      data-share-title="{{ share_title }}"
      aria-label="Compartilhar"
      title="Compartilhar"
      hidden
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
        <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
        <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
      </svg>
    </button>

    {%- comment -%} WhatsApp {%- endcomment -%}
    <a
      href="https://wa.me/?text={{ share_title | url_encode }}%20{{ share_url | url_encode }}"
      target="_blank"
      rel="noopener noreferrer"
      class="product-share__btn"
      aria-label="Compartilhar no WhatsApp"
      title="WhatsApp"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path fill="currentColor" d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
      </svg>
    </a>

    {%- comment -%} E-mail {%- endcomment -%}
    <a
      href="mailto:?subject={{ share_title | url_encode }}&body={{ share_url | url_encode }}"
      class="product-share__btn"
      aria-label="Compartilhar por e-mail"
      title="E-mail"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
        <rect x="2" y="4" width="20" height="16" rx="2"/>
        <path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"/>
      </svg>
    </a>

    {%- comment -%} Copy link {%- endcomment -%}
    <button
      class="product-share__btn product-share__copy-btn"
      data-copy-url="{{ share_url }}"
      aria-label="Copiar link do produto"
      title="Copiar link"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
        <path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/>
        <path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/>
      </svg>
      <span class="product-share__copy-feedback" aria-live="polite"></span>
    </button>

  </div>
</div>

<script>
  (function () {
    var root = document.getElementById('product-share-{{ block.id }}');
    if (!root) return;

    /* ── Copy link ── */
    var copyBtn = root.querySelector('.product-share__copy-btn');
    if (copyBtn) {
      copyBtn.addEventListener('click', function () {
        var url = this.dataset.copyUrl;
        navigator.clipboard.writeText(url).then(function () {
          var feedback = copyBtn.querySelector('.product-share__copy-feedback');
          if (!feedback) return;
          feedback.textContent = 'Copiado!';
          clearTimeout(copyBtn._feedbackTimer);
          copyBtn._feedbackTimer = setTimeout(function () {
            feedback.textContent = '';
          }, 2200);
        });
      });
    }

    /* ── Native share (mobile / modern browsers) ── */
    var nativeBtn = root.querySelector('.product-share__native-btn');
    if (nativeBtn && navigator.share) {
      nativeBtn.removeAttribute('hidden');
      nativeBtn.addEventListener('click', function () {
        navigator.share({
          title: this.dataset.shareTitle,
          url: this.dataset.shareUrl
        }).catch(function () {});
      });
    }
  })();
</script>

{% stylesheet %}
  .product-share {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .product-share__label {
    font-size: 0.75rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    opacity: 0.55;
    flex-shrink: 0;
    line-height: 1;
  }

  .product-share__buttons {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .product-share__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 1px solid currentColor;
    background: transparent;
    color: currentColor;
    opacity: 0.45;
    cursor: pointer;
    text-decoration: none;
    transition: opacity 0.18s ease, transform 0.18s ease;
    padding: 0;
    position: relative;
    flex-shrink: 0;
  }

  .product-share__btn:hover,
  .product-share__btn:focus-visible {
    opacity: 0.9;
    transform: scale(1.1);
    outline: none;
  }

  .product-share__btn svg {
    width: 15px;
    height: 15px;
    flex-shrink: 0;
    display: block;
  }

  /* Tooltip "Copiado!" acima do botão */
  .product-share__copy-feedback {
    position: absolute;
    bottom: calc(100% + 7px);
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-foreground);
    color: var(--color-background);
    font-size: 0.625rem;
    letter-spacing: 0.04em;
    padding: 3px 7px;
    border-radius: 4px;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.18s ease;
  }

  .product-share__copy-feedback:not(:empty) {
    opacity: 1;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Compartilhar",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Rótulo",
      "default": "Compartilhar"
    },
    {
      "type": "header",
      "content": "Espaçamento"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Topo",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Base",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 8
    }
  ]
}
{% endschema %}
