{%- liquid
  assign sid = section.id
  assign section_class = 'cards-section cards-section--' | append: sid
-%}

<div class="{{ section_class }}" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="cards-section__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="cards-section__carousel swiper" id="cards-carousel-{{ sid }}" data-cards-carousel>
      <div class="swiper-wrapper">
        {%- for block in section.blocks -%}
          {%- if block.type == 'card' -%}
          {%- assign has_video_url = 0 -%}
          {%- if block.settings.video_url != blank -%}{%- assign has_video_url = 1 -%}{%- endif -%}
          {%- assign has_video = 0 -%}
          {%- if block.settings.video != blank -%}{%- assign has_video = 1 -%}{%- endif -%}
          {%- assign has_image = 0 -%}
          {%- if block.settings.image != blank -%}{%- assign has_image = 1 -%}{%- endif -%}
          {%- assign has_media = 0 -%}
          {%- if has_video_url == 1 or has_video == 1 or has_image == 1 -%}{%- assign has_media = 1 -%}{%- endif -%}

          <div class="swiper-slide cards-section__slide" {{ block.shopify_attributes }}>
            <div class="cards-section__card{% if has_media != 1 %} cards-section__card--placeholder{% endif %}">
              {%- comment -%} Mídia (imagem, vídeo ou placeholder) {%- endcomment -%}
              <div class="cards-section__media">
                {%- if has_video_url == 1 -%}
                  {%- if block.settings.video_url.type == 'youtube' -%}
                    <iframe
                      id="cards-{{ sid }}-{{ block.id }}"
                      src="https://www.youtube.com/embed/{{ block.settings.video_url.id }}?autoplay=0&mute=1&loop=1&playlist={{ block.settings.video_url.id }}&controls=0&playsinline=1"
                      allow="autoplay; encrypted-media"
                      allowfullscreen
                      loading="lazy"
                      title=""
                    ></iframe>
                  {%- elsif block.settings.video_url.type == 'vimeo' -%}
                    <iframe
                      id="cards-{{ sid }}-{{ block.id }}"
                      src="https://player.vimeo.com/video/{{ block.settings.video_url.id }}?autoplay=0&muted=1&loop=1&title=0&byline=0"
                      allow="autoplay; encrypted-media"
                      allowfullscreen
                      loading="lazy"
                      title=""
                    ></iframe>
                  {%- endif -%}
                  <div class="cards-section__video-controls" data-video-controls data-embed="{{ block.settings.video_url.type }}" data-iframe="cards-{{ sid }}-{{ block.id }}">
                    <button type="button" data-video-play aria-label="Play/Pausar">▶</button>
                    <button type="button" data-video-mute aria-label="Mudo/Som">🔊</button>
                  </div>
                {%- elsif has_video == 1 -%}
                  {{ block.settings.video | video_tag: autoplay: false, loop: true, muted: false, playsinline: true, controls: false, class: 'cards-section__video-el' }}
                  <div class="cards-section__video-controls" data-video-controls data-embed="native">
                    <button type="button" data-video-play aria-label="Play/Pausar">▶</button>
                    <button type="button" data-video-mute aria-label="Mudo/Som">🔊</button>
                  </div>
                {%- elsif has_image == 1 -%}
                  {{ block.settings.image | image_url: width: 720 | image_tag: loading: 'lazy', widths: '360, 540, 720', sizes: '(max-width: 749px) 280px, 360px' }}
                {%- else -%}
                  <div class="cards-section__placeholder">&nbsp;</div>
                {%- endif -%}
              </div>

              <div class="cards-section__overlay"></div>

              <div class="cards-section__content">
                <div class="cards-section__info">
                  {%- if block.settings.client_name != blank -%}<p class="cards-section__name">{{ block.settings.client_name }}</p>{%- endif -%}
                  {%- if block.settings.client_location != blank -%}<p class="cards-section__location">{{ block.settings.client_location }}</p>{%- endif -%}
                </div>
                <div class="cards-section__stats">
                  <span class="cards-section__icon"><svg xmlns="http://www.w3.org/2000/svg" width="21" height="21" viewBox="0 0 21 21" fill="none">
                    <path d="M9.75 5.25C9.75 4.62868 10.2537 4.125 10.875 4.125C11.4963 4.125 12 4.62868 12 5.25V5.625H13.125C13.7463 5.625 14.25 6.12868 14.25 6.75C14.25 7.37132 13.7463 7.875 13.125 7.875H9.75C9.33579 7.875 9 8.21079 9 8.625C9 9.03921 9.33579 9.375 9.75 9.375H11.25C12.9069 9.375 14.25 10.7181 14.25 12.375C14.25 14.0319 12.9069 15.375 11.25 15.375V15.75C11.25 16.3713 10.7463 16.875 10.125 16.875C9.50368 16.875 9 16.3713 9 15.75V15.375H7.875C7.25368 15.375 6.75 14.8713 6.75 14.25C6.75 13.6287 7.25368 13.125 7.875 13.125H11.25C11.6642 13.125 12 12.7892 12 12.375C12 11.9608 11.6642 11.625 11.25 11.625H9.75C8.09315 11.625 6.75 10.2819 6.75 8.625C6.75 6.96815 8.09315 5.625 9.75 5.625V5.25Z" fill="#00C34D"/>
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M21 10.5C21 16.299 16.299 21 10.5 21C4.70101 21 0 16.299 0 10.5C0 4.70101 4.70101 0 10.5 0C16.299 0 21 4.70101 21 10.5ZM18.75 10.5C18.75 15.0563 15.0563 18.75 10.5 18.75C5.94365 18.75 2.25 15.0563 2.25 10.5C2.25 5.94365 5.94365 2.25 10.5 2.25C15.0563 2.25 18.75 5.94365 18.75 10.5Z" fill="#00C34D"/>
                  </svg></span>
                  <div>
                    {%- if block.settings.revenue_value != blank -%}<p class="cards-section__revenue">{{ block.settings.revenue_value }}</p>{%- endif -%}
                    {%- if block.settings.revenue_period != blank -%}<p class="cards-section__period">em <strong>{{ block.settings.revenue_period }}</strong></p>{%- endif -%}
                  </div>
                </div>
              </div>
            </div>
          </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

<style>
  .cards-section--{{ sid }} { min-height: 0; }
  .cards-section--{{ sid }} .page-width { min-height: 0; }

  .cards-section__carousel {
    margin: 0 -1.5rem;
    padding: 0 1.5rem;
    overflow: hidden;
    height: auto;
    min-height: 0;
  }

  .cards-section__carousel .swiper-wrapper {
    align-items: flex-start;
  }

  .cards-section__carousel .swiper-slide {
    height: auto !important;
    box-sizing: border-box;
  }

  .cards-section__heading {
    font-size: 40px;
    font-weight: 700;
    color: #4f4f4f;
    text-align: center;
    padding-bottom: 40px;
    margin: 0;
    line-height: 1.2;
  }

  .cards-section__slide {
    flex-shrink: 0;
    width: 360px !important;
    max-width: calc(100vw - 2rem);
  }

  .cards-section__card {
    position: relative;
    aspect-ratio: 9 / 16;
    min-height: 0;
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 24px;
    box-sizing: border-box;
  }

  .cards-section__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .cards-section__media img,
  .cards-section__media iframe,
  .cards-section__video-el {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .cards-section__media iframe {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%;
    height: 100%;
    min-width: 100%;
    min-height: 56.25%;
    transform: translate(-50%, -50%);
    border: none;
  }

  .cards-section__placeholder {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0) 50%, rgba(0,0,0,0.1) 100%), #e7e7e7;
  }

  .cards-section__video-controls {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 2;
    display: flex;
    gap: 8px;
  }

  .cards-section__video-controls button {
    width: 36px;
    height: 36px;
    border: none;
    border-radius: 50%;
    background: rgba(0,0,0,0.5);
    color: #fff;
    cursor: pointer;
    font-size: 14px;
    line-height: 1;
  }

  .cards-section__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(180deg, transparent 50%, rgba(0,0,0,0.8) 100%);
    border-radius: 8px;
    pointer-events: none;
  }

  .cards-section__content {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 12px;
  }

  .cards-section__name { margin: 0; font-size: 16px; font-weight: 600; color: #fff; line-height: 1.2; }
  .cards-section__location { margin: 4px 0 0; font-size: 12px; color: rgba(255,255,255,0.6); line-height: 1.2; }
  .cards-section__stats { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
  .cards-section__icon { font-size: 20px; }
  .cards-section__revenue { margin: 0; font-size: 12px; font-weight: 700; color: #00C34D; line-height: 1.2; }
  .cards-section__period { margin: 0; font-size: 12px; color: #fff; line-height: 1.2; }
  .cards-section__period strong { font-weight: 700; }

  .cards-section__card--placeholder .cards-section__overlay { display: none; }
  .cards-section__card--placeholder .cards-section__name { color: #5d5d5d; }
  .cards-section__card--placeholder .cards-section__location { color: rgba(109,109,109,0.6); }
  .cards-section__card--placeholder .cards-section__revenue,
  .cards-section__card--placeholder .cards-section__period { color: #6d6d6d; }

  @media (max-width: 749px) {
    .cards-section__heading { font-size: 24px; padding-bottom: 24px; }
    .cards-section__carousel { margin: 0 -1rem; padding: 0 1rem; }
    .cards-section__slide { width: 300px !important; }
    .cards-section__card { padding: 16px; }
    .cards-section__name { font-size: 14px; }
    .cards-section__location { font-size: 11px; }
    .cards-section__revenue,
    .cards-section__period { font-size: 11px; }
  }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>

<script>
(function() {
  var carousel = document.getElementById('cards-carousel-{{ sid }}');
  if (!carousel) return;

  function init() {
    if (carousel.dataset.inited === '1') return;
    if (typeof Swiper !== 'function') return setTimeout(init, 50);
    carousel.dataset.inited = '1';
    new Swiper(carousel, {
      slidesPerView: 'auto',
      spaceBetween: 24,
      freeMode: true,
      grabCursor: true,
      resistanceRatio: 0.6,
      breakpoints: {
        0:   { spaceBetween: 12 },
        750: { spaceBetween: 16 },
        990: { spaceBetween: 24 }
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  // Controles de vídeo (play/mute) – apenas vídeo nativo para manter simples
  var section = carousel.closest('.cards-section--{{ sid }}');
  if (!section) return;
  section.querySelectorAll('[data-video-controls][data-embed="native"]').forEach(function(bar) {
    var card = bar.closest('.cards-section__card');
    var video = card ? card.querySelector('video') : null;
    if (!video) return;
    var playBtn = bar.querySelector('[data-video-play]');
    var muteBtn = bar.querySelector('[data-video-mute]');
    if (playBtn) playBtn.addEventListener('click', function(e) { e.preventDefault(); video.paused ? video.play() : video.pause(); });
    if (muteBtn) muteBtn.addEventListener('click', function(e) { e.preventDefault(); video.muted = !video.muted; });
  });
})();
</script>

{% schema %}
{
  "name": "Cards de Clientes",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "heading", "label": "Título", "default": "Veja quem já faturou com a tremaque" },
    { "type": "header", "content": "Espaçamento" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Espaçamento superior", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Espaçamento inferior", "default": 40 }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Imagem de fundo" },
        { "type": "video", "id": "video", "label": "Vídeo (opcional)" },
        { "type": "video_url", "id": "video_url", "label": "YouTube ou Vimeo (opcional)", "accept": ["youtube", "vimeo"] },
        { "type": "text", "id": "client_name", "label": "Nome", "default": "Nome do Cliente" },
        { "type": "text", "id": "client_location", "label": "Trabalho, cidade-estado", "default": "trabalho, cidade-estado" },
        { "type": "text", "id": "revenue_value", "label": "Valor faturado", "default": "R$ 00.000,00" },
        { "type": "text", "id": "revenue_period", "label": "Período", "default": "3 Meses" }
      ]
    }
  ],
  "presets": [
    { "name": "Cards de Clientes", "blocks": [{ "type": "card" }, { "type": "card" }, { "type": "card" }, { "type": "card" }] }
  ]
}
{% endschema %}
