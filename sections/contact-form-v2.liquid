{%- style -%}
  .contact-form-v2-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .contact-form-v2-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .contact-form-v2-{{ section.id }} .contact-form-v2__grid {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
  }

  .contact-form-v2-{{ section.id }} .contact-form-v2__copy {
    flex: 0 0 504px;
    max-width: 504px;
  }

  .contact-form-v2-{{ section.id }} .contact-form-v2__title {
    margin: 0 0 24px 0;
    font-size: 40px;
    line-height: 62px;
    font-weight: 700;
    color: #4f4f4f;
  }

  .contact-form-v2-{{ section.id }} .contact-form-v2__subtitle {
    margin: 0;
    font-size: 18px;
    line-height: 1.4;
    font-weight: 400;
    color: #6d6d6d;
  }

  .contact-form-v2-{{ section.id }} .contact-form-v2__panel {
    max-width: 648px;
    width: 100%;
    background: #e7e7e7;
    border-radius: 12px;
    padding: 30px;
    overflow: hidden;
  }

  .contact-form-v2-{{ section.id }} .contact-form-v2__fields {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin: 0 0 20px 0;
  }

  .contact-form-v2-{{ section.id }} .contact-form-v2__field {
    position: relative;
  }

  .contact-form-v2-{{ section.id }} .contact-form-v2__input {
    width: 100%;
    border: 0;
    outline: none;
    border-radius: 12px;
    padding: 16px 24px;
    font-size: 18px;
    line-height: 1.2;
    background: #ffffff;
    color: #4f4f4f;
    box-sizing: border-box;
  }

  .contact-form-v2-{{ section.id }} .contact-form-v2__input::placeholder {
    color: #b0b0b0;
  }

  .contact-form-v2-{{ section.id }} .contact-form-v2__hint {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 0 0 20px 0;
    color: #6d6d6d;
    font-size: 14px;
    line-height: 16px;
  }

  .contact-form-v2-{{ section.id }} .contact-form-v2__hint-icon {
    width: 25px;
    height: 25px;
    flex: 0 0 25px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .contact-form-v2-{{ section.id }} .contact-form-v2__button {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    width: 199px;
    border: 0;
    cursor: pointer;
    background: #b10326;
    color: #ffffff;
    border-radius: 8px;
    padding: 16px;
    font-size: 16px;
    font-weight: 700;
    line-height: 1.5;
    flex-wrap: nowrap;
    white-space: nowrap;
  }

  .contact-form-v2-{{ section.id }} .contact-form-v2__button > span:first-child {
    white-space: nowrap;
  }

  .contact-form-v2-{{ section.id }} .contact-form-v2__button:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .contact-form-v2-{{ section.id }} .contact-form-v2__button-icon {
    width: 18px;
    height: 18px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 18px;
  }

  .contact-form-v2-{{ section.id }} .contact-form-v2__status {
    margin: 0 0 16px 0;
    font-size: 14px;
    line-height: 1.4;
    color: #4f4f4f;
  }

  .contact-form-v2-{{ section.id }} .contact-form-v2__status--error {
    color: #b10326;
  }

  @media screen and (max-width: 989px) {
    .contact-form-v2-{{ section.id }} .contact-form-v2__grid {
      flex-direction: column;
      align-items: stretch;
      gap: 24px;
    }

    .contact-form-v2-{{ section.id }} .contact-form-v2__copy {
      flex: 1 1 auto;
      max-width: 100%;
    }

    .contact-form-v2-{{ section.id }} .contact-form-v2__panel {
      max-width: 100%;
    }
  }

  @media screen and (max-width: 749px) {
    .contact-form-v2-{{ section.id }} .contact-form-v2__title {
      font-size: 28px;
      line-height: 1.15;
      margin-bottom: 16px;
    }

    .contact-form-v2-{{ section.id }} .contact-form-v2__subtitle {
      font-size: 16px;
    }

    .contact-form-v2-{{ section.id }} .contact-form-v2__fields {
      grid-template-columns: 1fr;
    }

    .contact-form-v2-{{ section.id }} .contact-form-v2__panel {
      padding: 20px;
      border-radius: 12px;
    }

    .contact-form-v2-{{ section.id }} .contact-form-v2__button {
      width: 100%;
      justify-content: center;
    }
  }
{%- endstyle -%}

{%- liquid
  # Always use the theme WhatsApp number (single source of truth)
  assign whatsapp_raw = settings.number_contato | default: ''
  assign whatsapp_number = whatsapp_raw | remove: ' ' | remove: '-' | remove: '(' | remove: ')' | remove: '+' | remove: '.'
  assign contact_form_v2_id = 'ContactFormV2-' | append: section.id

  # WhatsApp template for contact-form submissions
  # Priority: mensagem_contato > mensagem_home > mensagem_padrao (legacy) > hardcoded fallback
  assign contact_template = settings.mensagem_contato
  if contact_template == blank
    assign contact_template = settings.mensagem_home
  endif
  if contact_template == blank
    assign contact_template = settings.mensagem_padrao
  endif
  if contact_template == blank
    assign contact_template = 'Olá! Meu nome é {name} e gostaria de mais informações.\n\nTelefone: {phone}'
  endif
-%}
<div
  class="contact-form-v2-{{ section.id }}"
  data-whatsapp-number="{{ whatsapp_number | escape }}"
  data-whatsapp-template="{{ contact_template | escape }}"
  data-page-url="{{ request.origin | append: request.path | escape }}"
  data-shop-name="{{ shop.name | escape }}"
>
  <div class="page-width">
    <div class="contact-form-v2__grid">
      <div class="contact-form-v2__copy">
        {%- if section.settings.heading != blank -%}
          <h2 class="contact-form-v2__title">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="contact-form-v2__subtitle">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>

      <div class="contact-form-v2__panel">
        <form id="{{ contact_form_v2_id }}" class="contact-form-v2__form" novalidate>
          <div class="contact-form-v2__fields">
            <div class="contact-form-v2__field">
              <input
                class="contact-form-v2__input"
                type="text"
                id="ContactFormV2-name-{{ section.id }}"
                name="nome"
                autocomplete="name"
                placeholder="{{ section.settings.placeholder_name }}"
                value="{% if customer %}{{ customer.name }}{% endif %}"
                required
              >
            </div>

            <div class="contact-form-v2__field">
              <input
                class="contact-form-v2__input"
                type="tel"
                id="ContactFormV2-phone-{{ section.id }}"
                name="numero"
                autocomplete="tel"
                inputmode="numeric"
                placeholder="{{ section.settings.placeholder_phone }}"
                value="{% if customer %}{{ customer.phone }}{% endif %}"
                maxlength="16"
                required
              >
            </div>
          </div>

          {%- if section.settings.helper_text != blank -%}
            <div class="contact-form-v2__hint">
              <span class="contact-form-v2__hint-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z" stroke="#6D6D6D" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M12 6V12L16 14" stroke="#6D6D6D" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span>{{ section.settings.helper_text }}</span>
            </div>
          {%- endif -%}

          <p class="contact-form-v2__status contact-form-v2__status--error" id="ContactFormV2-status-{{ section.id }}" role="alert" aria-live="polite" hidden></p>

          <button type="submit" class="contact-form-v2__button" {% if whatsapp_number == blank %}disabled{% endif %}>
            <span>{{ section.settings.button_label }}</span>
            <span class="contact-form-v2__button-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M22 16.92V20.92C22 21.47 21.55 21.92 21 21.92C10.51 21.92 2.08 13.49 2.08 3C2.08 2.45 2.53 2 3.08 2H7.08C7.63 2 8.08 2.45 8.08 3C8.08 4.14 8.26 5.23 8.59 6.26C8.71 6.64 8.62 7.05 8.35 7.32L6.94 8.73C8.7 12.21 11.79 15.3 15.27 17.06L16.68 15.65C16.95 15.38 17.36 15.29 17.74 15.41C18.77 15.74 19.86 15.92 21 15.92C21.55 15.92 22 16.37 22 16.92Z" fill="white"/>
              </svg>
            </span>
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    const wrapper = document.querySelector('.contact-form-v2-{{ section.id }}');
    const form = document.getElementById('ContactFormV2-{{ section.id }}');
    if (!form || !wrapper) return;

    const phoneEl = form.querySelector('#ContactFormV2-phone-{{ section.id }}');
    const nameEl = form.querySelector('#ContactFormV2-name-{{ section.id }}');
    const whatsappNumber = (wrapper.dataset.whatsappNumber || '').replace(/\D/g, '');

    function digitsOnly(value) {
      return (value || '').toString().replace(/\D/g, '');
    }

    function formatPhoneBR(digits) {
      const d = (digits || '').toString().replace(/\D/g, '').slice(0, 11);
      if (!d) return '';

      const ddd = d.slice(0, 2);
      const rest = d.slice(2);

      if (d.length <= 2) return `(${ddd}`;
      if (d.length <= 6) return `(${ddd}) ${rest}`;

      const useNineDigit = rest.length > 8;
      const part1 = rest.slice(0, useNineDigit ? 5 : 4);
      const part2 = rest.slice(useNineDigit ? 5 : 4, useNineDigit ? 9 : 8);
      return `(${ddd}) ${part1}${part2 ? '-' + part2 : ''}`;
    }

    function setCaretByDigitIndex(input, digitIndex) {
      if (typeof input.selectionStart !== 'number' || typeof input.setSelectionRange !== 'function') return;
      const value = input.value || '';
      if (digitIndex <= 0) {
        input.setSelectionRange(0, 0);
        return;
      }
      let digitsSeen = 0;
      for (let i = 0; i < value.length; i++) {
        if (/\d/.test(value[i])) digitsSeen += 1;
        if (digitsSeen >= digitIndex) {
          input.setSelectionRange(i + 1, i + 1);
          return;
        }
      }
      input.setSelectionRange(value.length, value.length);
    }

    function applyPhoneMask() {
      if (!phoneEl) return;
      const current = phoneEl.value || '';
      const pos = typeof phoneEl.selectionStart === 'number' ? phoneEl.selectionStart : current.length;
      const digitsBefore = digitsOnly(current.slice(0, pos)).length;

      const formatted = formatPhoneBR(digitsOnly(current));
      if (formatted === current) return;

      phoneEl.value = formatted;
      try {
        setCaretByDigitIndex(phoneEl, digitsBefore);
      } catch (e) {}
    }

    applyPhoneMask();
    phoneEl?.addEventListener('input', applyPhoneMask);
    phoneEl?.addEventListener('blur', applyPhoneMask);

    const statusEl = form.querySelector('#ContactFormV2-status-{{ section.id }}');
    function clearStatusOnInput() {
      showStatus('');
    }
    nameEl?.addEventListener('input', clearStatusOnInput);
    nameEl?.addEventListener('focus', clearStatusOnInput);
    phoneEl?.addEventListener('input', clearStatusOnInput);
    phoneEl?.addEventListener('focus', clearStatusOnInput);
    const emptyMessage = {{ section.settings.empty_fields_message | default: 'Por favor, preencha seu nome e número de contato para continuar.' | json }};

    function showStatus(text) {
      if (!statusEl) return;
      statusEl.textContent = text || '';
      statusEl.hidden = !text;
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      if (!whatsappNumber) return;

      const nome = (nameEl && nameEl.value) ? nameEl.value.trim() : '';
      const numero = (phoneEl && phoneEl.value) ? phoneEl.value.trim() : '';

      if (!nome || !numero) {
        showStatus(emptyMessage);
        return;
      }

      showStatus('');

      const template = (wrapper.dataset.whatsappTemplate || '').toString();
      const pageUrl = (wrapper.dataset.pageUrl || '').toString();
      const shopName = (wrapper.dataset.shopName || '').toString();

      // Supported placeholders: {name} {phone} {page_url} {shop_name}
      // If the template doesn't mention phone, we append it at the end.
      let mensagem = template
        .replaceAll('{name}', nome)
        .replaceAll('{phone}', numero)
        .replaceAll('{page_url}', pageUrl)
        .replaceAll('{shop_name}', shopName);

      if (!mensagem.includes(numero)) {
        mensagem += `\n\nMeu número de contato: ${numero}`;
      }

      const url = 'https://wa.me/' + whatsappNumber + '?text=' + encodeURIComponent(mensagem);
      window.open(url, '_blank', 'noopener,noreferrer');
    });
  })();
</script>

{% schema %}
{
  "name": "Contact form v2",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Ligamos pra você!"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Texto",
      "default": "Tem dúvidas, deseja mais informações ou quer começar um projeto? Nossa equipe está pronta para ajudar."
    },
    {
      "type": "text",
      "id": "placeholder_name",
      "label": "Placeholder do nome",
      "default": "Seu nome"
    },
    {
      "type": "text",
      "id": "placeholder_phone",
      "label": "Placeholder do telefone",
      "default": "Seu número para contato"
    },
    {
      "type": "text",
      "id": "helper_text",
      "label": "Texto auxiliar",
      "default": "Entraremos em contato em até 30 minutos no horário comercial (Seg-Sex, 9h–18h)"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto do botão",
      "default": "Entrar em contato"
    },
    {
      "type": "paragraph",
      "content": "O Contact form v2 usa sempre o número do WhatsApp configurado nas configurações do tema (Botão Contato)."
    },
    {
      "type": "text",
      "id": "empty_fields_message",
      "label": "Aviso quando não preencher",
      "default": "Por favor, preencha seu nome e número de contato para continuar."
    },
    {
      "type": "header",
      "content": "Espaçamento"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espaçamento superior",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espaçamento inferior",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Contact form v2"
    }
  ]
}
{% endschema %}
