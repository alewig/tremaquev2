{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

{%- style -%}
 .footer-block__heading {
   color: {{ section.settings.color_footer_heading }} !important;
 }
 .footer-block__subheading{
    leading-trim: both;
    text-edge: cap;
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: 150%;
 }
 .footer-block__contact-payment{
  display: grid;
    gap: 1rem;
}
  .footer {
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  .footer-block__payment-seals-container {
    padding-top: 32px;
  }

  .footer-block__contact-item {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }

  .footer-block__contact-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .footer-block__contact-icon svg {
    width: 20px;
    height: 20px;
  }

  .footer-block__contact-text {
    flex: 1;
    min-width: 0;
    max-width: 100%;
    overflow-wrap: break-word;
    word-wrap: break-word;
    word-break: break-word;
  }
  .footer-block__security-image img{
    width: 100%;
    height: 100%;
  }
  
  .footer-block__seals {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  
  .footer-block__payment-seals-section,
  .footer-block__security-seals {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  
  
  .footer-block__payment-content {
    margin: 0;
  }
  
  .footer-block__payment-image {
    margin-top: 0;
  }
  
  .footer-block__payment-image img {
    max-width: 100%;
    height: auto;
  }
  
  .footer-block__payment-seals-section {
    width: 100%;
  }
  
  .footer-block__security-seals {
    width: 100%;
  }
  
  .footer-block__security-images-wrapper {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: flex-start;
  }
  
  .footer-block__security-image {
    margin: 0;
    min-width: 0;
    width: var(--security-image-size, 30px);
    height: var(--security-image-size, 30px);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .footer-block__security-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .footer-block__security-link {
    display: block;
    width: 100%;
    height: 100%;
    line-height: 0;
  }

  .footer-block__security-link img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .footer-block__reclame-aqui-section {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .footer-block__reclame-aqui-seal {
    min-height: 40px;
  }

  .footer-block__link-lists {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 100%;
  }
  
  .footer-block__link-list-item {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 100%;
    min-width: 0;
  }

  .footer-block__link-list-item .footer-block__details-content {
    max-width: 100%;
  }

  .footer-block__link-list-item .list-menu__item {
    overflow-wrap: break-word;
    word-wrap: break-word;
    word-break: break-word;
  }

  @media screen and (min-width: 750px) {
    .footer {
      margin-top: {{ section.settings.margin_top }}px;
    }

    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  @media screen and (max-width: 980px) {
    .footer-block__contact-text {
      font-size: 14px;
    }
  }

  /* Correções de responsividade para tablets e laptops */
  .footer__blocks-wrapper .grid__item {
    min-width: 0;
    box-sizing: border-box;
    overflow-wrap: break-word;
    word-wrap: break-word;
    word-break: break-word;
  }

  .footer-block__details-content,
  .footer-block__contact-text,
  .footer-block__heading,
  .footer-block__subheading,
  .footer-block__payment-content,
  .rte {
    max-width: 100%;
    overflow-wrap: break-word;
    word-wrap: break-word;
    word-break: break-word;
    hyphens: auto;
  }

  /* Media queries para tablets (750px - 989px) */
  @media screen and (min-width: 750px) and (max-width: 989px) {
    .footer__blocks-wrapper .grid__item {
      min-width: 0;
      max-width: 100%;
    }

    .footer-block__details-content,
    .footer-block__contact-text,
    .footer-block__heading,
    .footer-block__subheading,
    .footer-block__payment-content {
      max-width: 100%;
      overflow-wrap: break-word;
      word-wrap: break-word;
    }

    .footer-block__contact-item {
      flex-wrap: wrap;
    }

    .footer-block__contact-text {
      min-width: 0;
      flex: 1 1 auto;
    }
  }

  /* Media queries para laptops (990px - 1366px) */
  @media screen and (min-width: 990px) and (max-width: 1366px) {
    .footer__blocks-wrapper .grid__item {
      min-width: 0;
      max-width: 100%;
    }

    .footer-block__details-content,
    .footer-block__contact-text,
    .footer-block__heading,
    .footer-block__subheading,
    .footer-block__payment-content,
    .rte {
      max-width: 100%;
      overflow-wrap: break-word;
      word-wrap: break-word;
    }

    .footer-block__contact-item {
      flex-wrap: wrap;
    }

    .footer-block__contact-text {
      min-width: 0;
      flex: 1 1 auto;
    }

    /* Garantir que imagens não ultrapassem */
    .footer-block__payment-image img,
    .footer-block__payment-seals-image img {
      max-width: 100%;
      height: auto;
    }
  }
{%- endstyle -%}

<footer class="footer color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  {%- liquid
    assign has_social_icons = true
    if settings.social_facebook_link == blank and settings.social_instagram_link == blank and settings.social_youtube_link == blank and settings.social_tiktok_link == blank and settings.social_twitter_link == blank and settings.social_pinterest_link == blank and settings.social_snapchat_link == blank and settings.social_tumblr_link == blank and settings.social_vimeo_link == blank
      assign has_social_icons = false
    endif

    if settings.brand_image == blank and settings.brand_headline == blank and settings.brand_description == blank
      assign brand_empty = true
    endif

    if section.blocks.size == 1 and section.blocks[0].type == 'brand_information' and brand_empty and has_social_icons == false and section.settings.newsletter_enable == false and section.settings.enable_follow_on_shop == false
      assign only_empty_brand = true
    endif
  -%}
  {%- if section.blocks.size > 0
    or section.settings.newsletter_enable
    or section.settings.show_social
    and has_social_icons == true
    or section.settings.enable_follow_on_shop
  -%}
    {%- unless only_empty_brand -%}
      <div class="footer__content-top page-width">
        {%- if section.blocks.size > 0 -%}
          {%- liquid
            if section.blocks.size == 9
              assign footer_grid_class = 'grid--3-col-tablet'
            elsif section.blocks.size > 6
              assign footer_grid_class = 'grid--4-col-desktop'
            elsif section.blocks.size > 4
              assign footer_grid_class = 'grid--3-col-tablet'
            endif
          -%}
          <div
            class="footer__blocks-wrapper grid grid--1-col grid--2-col grid--4-col-tablet {{ footer_grid_class }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
            {% endif %}
          >
            {%- for block in section.blocks -%}
              <div
                class="footer-block grid__item{% if block.type == 'link_list' %} footer-block--menu{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                {{ block.shopify_attributes }}
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
              >
               
                {%- if block.type == 'text' and block.settings.section_order == 'payment_first' -%}
                  {%- if block.settings.show_payment_seals -%}
                  <div class="footer-block__payment-seals-container">
                    {%- if block.settings.payment_seals_heading != blank -%}
                      <h2 class="footer-block__heading inline-richtext">{{ block.settings.payment_seals_heading }}</h2>
                    {%- endif -%}
                  <div class="footer-block__details-content rte">
                      {{ block.settings.payment_seals_content }}
                      {%- if block.settings.payment_seals_image != blank -%}
                        <div class="footer-block__payment-seals-image">
                          {%- assign image_width = block.settings.payment_seals_image_width | default: 300 -%}
                          {{ block.settings.payment_seals_image | image_url: width: 800, height: 800 | image_tag }}
                    </div>
                      {%- endif -%}
                  </div>
                 </div>
                {%- endif -%}
                {%- if block.settings.heading != blank -%}
                  <div class="footer-block__heading-container">
                  {%- if block.settings.svg_icon != blank -%}
                    <div class="footer-block__svg-icon">
                      {{ block.settings.svg_icon }}
                    </div>
                  {%- endif -%}
                  <h2 class="footer-block__heading inline-richtext">{{- block.settings.heading -}}</h2>
                 </div>   
                  {%- endif -%}
                  {%- if block.type == 'text' -%}
                    <div class="footer-block__details-content rte">
                      {{ block.settings.subtext }}
                    </div>
                  {%- endif -%}
                {%- elsif block.type == 'text' -%}
                  {%- if block.settings.heading != blank -%}
                    <div class="footer-block__heading-container">
                    {%- if block.settings.svg_icon != blank -%}
                      <div class="footer-block__svg-icon">
                        {{ block.settings.svg_icon }}
                      </div>
                    {%- endif -%}
                    <h2 class="footer-block__heading inline-richtext">{{- block.settings.heading -}}</h2>
                   </div>   
                  {%- endif -%}
                  {%- if block.type == 'text' -%}
                    <div class="footer-block__details-content rte">
                      {{ block.settings.subtext }}
                    </div>
                  {%- endif -%}
                  {%- if block.settings.show_payment_seals -%}
                  <div class="footer-block__payment-seals-container">
                    {%- if block.settings.payment_seals_heading != blank -%}
                      <h2 class="footer-block__heading inline-richtext">{{ block.settings.payment_seals_heading }}</h2>
                    {%- endif -%}
                    <div class="footer-block__details-content rte">
                      {{ block.settings.payment_seals_content }}
                      {%- if block.settings.payment_seals_image != blank -%}
                        <div class="footer-block__payment-seals-image">
                          {%- assign image_width = block.settings.payment_seals_image_width | default: 300 -%}
                          {{ block.settings.payment_seals_image | image_url: width: image_width | image_tag }}
                        </div>
                      {%- endif -%}
                    </div>
                   </div>
                  {%- endif -%}
                {%- endif -%}

                {%- case block.type -%}
                  {%- when '@app' -%}
                    {% render block %}
                  {%- when 'text' -%}
                    {%- comment -%} Content is already handled in the section order logic above {%- endcomment -%}
                  {%- when 'contact_payment' -%}
                    <div class="footer-block__contact-payment">
                      {%- if block.settings.contact_heading != blank -%}
                        <h2 class="footer-block__heading inline-richtext">{{ block.settings.contact_heading }}</h2>
                      {%- endif -%}
                      {%- if block.settings.contact_subheading != blank -%}
                        <h3 class="footer-block__subheading inline-richtext">{{ block.settings.contact_subheading }}</h3>
                      {%- endif -%}
                      {%- if block.settings.contact_subheading2 != blank -%}
                        <h3 class="footer-block__subheading inline-richtext">{{ block.settings.contact_subheading2 }}</h3>
                      {%- endif -%}
                      <div class="footer-block__contact-items">
                        {%- for i in (1..3) -%}
                          {%- assign contact_text = 'contact_text_' | append: i -%}
                          {%- assign contact_icon = 'contact_icon_' | append: i -%}
                          {%- if block.settings[contact_text] != blank -%}
                            <div class="footer-block__contact-item">
                              {%- if block.settings[contact_icon] != blank -%}
                                <div class="footer-block__contact-icon">
                                  {{ block.settings[contact_icon] }}
                                </div>
                              {%- endif -%}
                              <div class="footer-block__contact-text rte">
                                {{ block.settings[contact_text] }}
                              </div>
                            </div>
                          {%- endif -%}
                        {%- endfor -%}
                      </div>
                      
                      {%- if block.settings.show_payment_seals -%}
                        <div class="footer-block__payment-seals-section" style="margin-top: 32px;">
                          {%- if block.settings.payment_seals_heading != blank -%}
                            <h3 class="footer-block__payment-heading">{{ block.settings.payment_seals_heading }}</h3>
                          {%- endif -%}
                          <div class="footer-block__payment-content rte">
                            {{ block.settings.payment_seals_content }}
                          </div>
                          {%- if block.settings.payment_seals_image != blank -%}
                            <div class="footer-block__payment-image">
                              {%- assign payment_image_width = block.settings.payment_seals_image_width | default: 300 -%}
                              {{ block.settings.payment_seals_image | image_url: width: payment_image_width | image_tag }}
                            </div>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                    </div>
                  {%- when 'newsletter_security' -%}
                    <div class="footer-block__newsletter-security">
                      {%- if block.settings.newsletter_heading != blank -%}
                        <h2 class="footer-block__heading inline-richtext">{{ block.settings.newsletter_heading }}</h2>
                      {%- endif -%}
                      {%- form 'customer', id: 'ContactFooterNewsletter', class: 'footer__newsletter newsletter-form' -%}
                        <input type="hidden" name="contact[tags]" value="newsletter">
                        <div class="newsletter-form__field-wrapper">
                          <div class="field">
                            <input
                              id="NewsletterForm--{{ section.id }}-{{ block.id }}"
                              type="email"
                              name="contact[email]"
                              class="field__input"
                              value="{{ form.email }}"
                              aria-required="true"
                              autocorrect="off"
                              autocapitalize="off"
                              autocomplete="email"
                              {% if form.errors %}
                                autofocus
                                aria-invalid="true"
                                aria-describedby="ContactFooterNewsletter-error"
                              {% elsif form.posted_successfully? %}
                                aria-describedby="ContactFooterNewsletter-success"
                              {% endif %}
                              placeholder="{{ 'newsletter.label' | t }}"
                              required
                            >
                            <label class="field__label" for="NewsletterForm--{{ section.id }}-{{ block.id }}">
                              {{ 'newsletter.label' | t }}
                            </label>
                            <button
                              type="submit"
                              class="newsletter-form__button field__button"
                              name="commit"
                              id="SubscribeNewsletter"
                              aria-label="{{ 'newsletter.button_label' | t }}"
                            >
                              <span class="svg-wrapper">
                                {{- 'icon-arrow.svg' | inline_asset_content -}}
                              </span>
                            </button>
                          </div>
                          {%- if form.errors -%}
                            <small class="newsletter-form__message form__message" id="ContactFooterNewsletter-error">
                              <span class="svg-wrapper">
                                {{- 'icon-error.svg' | inline_asset_content -}}
                              </span>
                              {{- form.errors.translated_fields.email | capitalize }}
                              {{ form.errors.messages.email -}}
                            </small>
                          {%- endif -%}
                        </div>
                        {%- if form.posted_successfully? -%}
                          <h3
                            class="newsletter-form__message newsletter-form__message--success form__message"
                            id="ContactFooterNewsletter-success"
                            tabindex="-1"
                            autofocus
                          >
                            <span class="svg-wrapper">
                              {{- 'icon-success.svg' | inline_asset_content -}}
                            </span>
                            {{- 'newsletter.success' | t }}
                          </h3>
                        {%- endif -%}
                      {%- endform -%}
                      
                      {%- if block.settings.show_security_seals -%}
                        <div class="footer-block__security-seals" style="margin-top: 32px;">
                          {%- if block.settings.security_seals_heading != blank -%}
                            <h3 class="footer-block__security-heading">{{ block.settings.security_seals_heading }}</h3>
                          {%- endif -%}
                          {%- if block.settings.security_seals_image != blank -%}
                            <div class="footer-block__security-image">
                              {{ block.settings.security_seals_image | image_url: width: 400 | image_tag }}
                            </div>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                    </div>
                  {%- when 'link_list' -%}
                    <div class="footer-block__link-lists">
                      {%- comment -%} Menu 1 {%- endcomment -%}
                      {%- if block.settings.heading != blank or block.settings.menu != blank -%}
                        <div class="footer-block__link-list-item">
                          {%- if block.settings.heading != blank -%}
                            <h2 class="footer-block__heading inline-richtext">{{ block.settings.heading }}</h2>
                          {%- endif -%}
                          {%- if block.settings.menu != blank -%}
                            <ul class="footer-block__details-content list-unstyled">
                              {%- for link in block.settings.menu.links -%}
                                <li>
                                  <a
                                    href="{{ link.url }}"
                                    class="link link--text list-menu__item list-menu__item--link{% if link.active %} list-menu__item--active{% endif %}"
                                  >
                                    {{ link.title | escape }}
                                  </a>
                                </li>
                              {%- endfor -%}
                            </ul>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                      
                      {%- comment -%} Menu 2 {%- endcomment -%}
                      {%- if block.settings.heading_2 != blank or block.settings.menu_2 != blank -%}
                        <div class="footer-block__link-list-item">
                          {%- if block.settings.heading_2 != blank -%}
                            <h2 class="footer-block__heading inline-richtext">{{ block.settings.heading_2 }}</h2>
                          {%- endif -%}
                          {%- if block.settings.menu_2 != blank -%}
                            <ul class="footer-block__details-content list-unstyled">
                              {%- for link in block.settings.menu_2.links -%}
                                <li>
                                  <a
                                    href="{{ link.url }}"
                                    class="link link--text list-menu__item list-menu__item--link{% if link.active %} list-menu__item--active{% endif %}"
                                  >
                                    {{ link.title | escape }}
                                  </a>
                                </li>
                              {%- endfor -%}
                            </ul>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                      
                      {%- comment -%} Menu 3 {%- endcomment -%}
                      {%- if block.settings.heading_3 != blank or block.settings.menu_3 != blank -%}
                        <div class="footer-block__link-list-item">
                          {%- if block.settings.heading_3 != blank -%}
                            <h2 class="footer-block__heading inline-richtext">{{ block.settings.heading_3 }}</h2>
                          {%- endif -%}
                          {%- if block.settings.menu_3 != blank -%}
                            <ul class="footer-block__details-content list-unstyled">
                              {%- for link in block.settings.menu_3.links -%}
                                <li>
                                  <a
                                    href="{{ link.url }}"
                                    class="link link--text list-menu__item list-menu__item--link{% if link.active %} list-menu__item--active{% endif %}"
                                  >
                                    {{ link.title | escape }}
                                  </a>
                                </li>
                              {%- endfor -%}
                            </ul>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                    </div>
                  {%- when 'menu' -%}
                    {%- if block.settings.heading != blank -%}
                      <h2 class="footer-block__heading inline-richtext {{ block.settings.heading_size }}">{{ block.settings.heading }}</h2>
                    {%- endif -%}
                    {%- if block.settings.menu != blank -%}
                      <ul class="footer-block__details-content list-unstyled">
                        {%- for link in block.settings.menu.links -%}
                          <li>
                            <a
                              href="{{ link.url }}"
                              class="link link--text list-menu__item list-menu__item--link{% if link.active %} list-menu__item--active{% endif %}"
                            >
                              {{ link.title | escape }}
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                  {%- when 'SealsAndSecurity' -%}
                    <div class="footer-block__seals">
                      {%- if block.settings.show_payment_seals -%}
                        <div class="footer-block__payment-seals-section">
                          {%- if block.settings.payment_seals_heading != blank -%}
                            <h2 class="footer-block__heading inline-richtext">{{ block.settings.payment_seals_heading }}</h2>
                          {%- endif -%}
                          {%- if block.settings.payment_seals_content != blank -%}
                            <div class="footer-block__payment-content rte">
                              {{ block.settings.payment_seals_content }}
                            </div>
                          {%- endif -%}
                          {%- if block.settings.payment_seals_image != blank -%}
                            <div class="footer-block__payment-image">
                              {%- assign payment_image_width = block.settings.payment_seals_image_width | default: 300 -%}
                              {{ block.settings.payment_seals_image | image_url: width: payment_image_width | image_tag: loading: 'lazy' }}
                            </div>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                      
                      {%- if block.settings.show_security_seals -%}
                        <div class="footer-block__security-seals">
                          {%- if block.settings.security_seals_heading != blank -%}
                            <h2 class="footer-block__heading inline-richtext">{{ block.settings.security_seals_heading }}</h2>
                          {%- endif -%}
                          {%- assign security_image_size = block.settings.security_seals_image_width | default: 30 -%}
                          <div class="footer-block__security-images-wrapper" style="--security-image-size: {{ security_image_size }}px;">
                            {%- if block.settings.security_seals_image_1 != blank -%}
                              <div class="footer-block__security-image">
                                {%- if block.settings.security_seals_link_1 != blank -%}
                                  <a href="{{ block.settings.security_seals_link_1 }}" target="_blank" rel="noopener noreferrer" class="footer-block__security-link">
                                    {{ block.settings.security_seals_image_1 | image_url: width: 100 | image_tag: loading: 'lazy' }}
                                  </a>
                                {%- else -%}
                                  {{ block.settings.security_seals_image_1 | image_url: width: 100 | image_tag: loading: 'lazy' }}
                                {%- endif -%}
                              </div>
                            {%- endif -%}
                            {%- if block.settings.security_seals_image_2 != blank -%}
                              <div class="footer-block__security-image">
                                {%- if block.settings.security_seals_link_2 != blank -%}
                                  <a href="{{ block.settings.security_seals_link_2 }}" target="_blank" rel="noopener noreferrer" class="footer-block__security-link">
                                    {{ block.settings.security_seals_image_2 | image_url: width: 100 | image_tag: loading: 'lazy' }}
                                  </a>
                                {%- else -%}
                                  {{ block.settings.security_seals_image_2 | image_url: width: 100 | image_tag: loading: 'lazy' }}
                                {%- endif -%}
                              </div>
                            {%- endif -%}
                            {%- if block.settings.security_seals_image_3 != blank -%}
                              <div class="footer-block__security-image">
                                {%- if block.settings.security_seals_link_3 != blank -%}
                                  <a href="{{ block.settings.security_seals_link_3 }}" target="_blank" rel="noopener noreferrer" class="footer-block__security-link">
                                    {{ block.settings.security_seals_image_3 | image_url: width: 100 | image_tag: loading: 'lazy' }}
                                  </a>
                                {%- else -%}
                                  {{ block.settings.security_seals_image_3 | image_url: width: 100 | image_tag: loading: 'lazy' }}
                                {%- endif -%}
                              </div>
                            {%- endif -%}
                          </div>
                        </div>
                      {%- endif -%}
                      {%- if block.settings.reclame_aqui_code != blank -%}
                        <div class="footer-block__reclame-aqui-section">
                          {{ block.settings.reclame_aqui_code }}
                        </div>
                      {%- endif -%}
                    </div>
                  {%- when 'brand_information' -%}
                    <div class="footer-block__brand-info">
                      {%- if settings.brand_image != blank -%}
                        {%- assign brand_image_height = settings.brand_image_width
                          | divided_by: settings.brand_image.aspect_ratio
                        -%}
                        <div
                          class="footer-block__image-wrapper"
                          style="max-width: min(100%, {{ settings.brand_image_width }}px);"
                        >
                          {{
                            settings.brand_image
                            | image_url: width: 1100
                            | image_tag:
                              loading: 'lazy',
                              widths: '50, 100, 150, 200, 300, 400, 550, 800, 1100',
                              height: brand_image_height,
                              width: settings.brand_image_width
                          }}
                        </div>
                      {%- endif -%}
                      {%- if settings.brand_headline != blank -%}
                        <h2 class="footer-block__heading rte">{{ settings.brand_headline }}</h2>
                      {%- endif -%}
                      {%- if settings.brand_description != blank -%}
                        <div class="rte">{{ settings.brand_description }}</div>
                      {%- endif -%}
                      {%- if block.settings.show_social and has_social_icons -%}
                        {%- render 'social-icons', class: 'footer__list-social', color: section.settings.social_icons_color -%}
                      {%- endif -%}
                    </div>
                  {%- when 'image' -%}
                    <div class="footer-block__details-content footer-block-image {{ block.settings.alignment }}">
                      {%- if block.settings.image != blank -%}
                        {%- assign image_size_2x = block.settings.image_width | times: 2 | at_most: 5760 -%}
                        <div
                          class="footer-block__image-wrapper"
                          style="max-width: min(100%, {{ block.settings.image_width }}px);"
                        >
                          <img
                            srcset="{{ block.settings.image | image_url: width: block.settings.image_width }}, {{ block.settings.image | image_url: width: image_size_2x }} 2x"
                            src="{{ block.settings.image | image_url: width: 760 }}"
                            alt="{{ block.settings.image.alt | escape }}"
                            loading="lazy"
                            width="{{ block.settings.image.width }}"
                            height="{{ block.settings.image.height }}"
                          >
                        </div>
                      {%- else -%}
                        {{ 'image' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
                      {%- endif -%}
                    </div>
                {%- endcase -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

        <div
          class="footer-block--newsletter{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          {% if settings.animations_reveal_on_scroll %}
            data-cascade
          {% endif %}
        >
          {%- if section.settings.newsletter_enable -%}
            <div class="footer-block__newsletter">
              {%- if section.settings.newsletter_heading != blank -%}
                <h2 class="footer-block__heading inline-richtext">{{ section.settings.newsletter_heading }}</h2>
              {%- endif -%}
              {%- form 'customer', id: 'ContactFooter', class: 'footer__newsletter newsletter-form' -%}
                <input type="hidden" name="contact[tags]" value="newsletter">
                <div class="newsletter-form__field-wrapper">
                  <div class="field">
                    <input
                      id="NewsletterForm--{{ section.id }}"
                      type="email"
                      name="contact[email]"
                      class="field__input"
                      value="{{ form.email }}"
                      aria-required="true"
                      autocorrect="off"
                      autocapitalize="off"
                      autocomplete="email"
                      {% if form.errors %}
                        autofocus
                        aria-invalid="true"
                        aria-describedby="ContactFooter-error"
                      {% elsif form.posted_successfully? %}
                        aria-describedby="ContactFooter-success"
                      {% endif %}
                      placeholder="{{ 'newsletter.label' | t }}"
                      required
                    >
                    <label class="field__label" for="NewsletterForm--{{ section.id }}">
                      {{ 'newsletter.label' | t }}
                    </label>
                    <button
                      type="submit"
                      class="newsletter-form__button field__button"
                      name="commit"
                      id="Subscribe"
                      aria-label="{{ 'newsletter.button_label' | t }}"
                    >
                      <span class="svg-wrapper">
                        {{- 'icon-arrow.svg' | inline_asset_content -}}
                      </span>
                    </button>
                  </div>
                  {%- if form.errors -%}
                    <small class="newsletter-form__message form__message" id="ContactFooter-error">
                      <span class="svg-wrapper">
                        {{- 'icon-error.svg' | inline_asset_content -}}
                      </span>
                      {{- form.errors.translated_fields.email | capitalize }}
                      {{ form.errors.messages.email -}}
                    </small>
                  {%- endif -%}
                </div>
                {%- if form.posted_successfully? -%}
                  <h3
                    class="newsletter-form__message newsletter-form__message--success form__message"
                    id="ContactFooter-success"
                    tabindex="-1"
                    autofocus
                  >
                    <span class="svg-wrapper">
                      {{- 'icon-success.svg' | inline_asset_content -}}
                    </span>
                    {{- 'newsletter.success' | t }}
                  </h3>
                {%- endif -%}
              {%- endform -%}
            </div>
          {%- endif -%}

          {%- if shop.features.follow_on_shop? and section.settings.enable_follow_on_shop -%}
            <div class="footer__follow-on-shop">
              {{ shop | login_button: action: 'follow' }}
            </div>
          {%- endif -%}

          {%- if section.settings.show_social and has_social_icons -%}
            {%- render 'social-icons', class: 'footer__list-social', color: section.settings.social_icons_color -%}
          {%- endif -%}
        </div>
      </div>
    {%- endunless -%}
  {%- endif -%}

  <div
    class="footer__content-bottom{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
    {% if settings.animations_reveal_on_scroll %}
      data-cascade
    {% endif %}
  >
    <div class="footer__content-bottom-wrapper page-width">
      <div class="footer__column footer__localization isolate">
        {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
          <localization-form>
            {%- form 'localization', id: 'FooterCountryForm', class: 'localization-form' -%}
              <div>
                <h2 class="caption-large text-body" id="FooterCountryLabel">{{ 'localization.country_label' | t }}</h2>
                {%- render 'country-localization', localPosition: 'FooterCountry' -%}
              </div>
            {%- endform -%}
          </localization-form>
        {%- endif -%}

        {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
          <localization-form>
            {%- form 'localization', id: 'FooterLanguageForm', class: 'localization-form' -%}
              <div>
                <h2 class="caption-large text-body" id="FooterLanguageLabel">
                  {{ 'localization.language_label' | t }}
                </h2>
                {%- render 'language-localization', localPosition: 'FooterLanguage' -%}
              </div>
            {%- endform -%}
          </localization-form>
        {%- endif -%}
      </div>
      <div class="footer__column footer__column--info">
        {%- if section.settings.payment_enable -%}
          <div class="footer__payment">
            <span class="visually-hidden">{{ 'sections.footer.payment' | t }}</span>
            <ul class="list list-payment" role="list">
              {%- for type in shop.enabled_payment_types -%}
                <li class="list-payment__item">
                  {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      </div>
    </div>
    <div class="footer__content-bottom-wrapper page-width{% if section.settings.enable_country_selector == false and section.settings.enable_language_selector == false %} footer__content-bottom-wrapper--center{% endif %}">
      <div class="footer__copyright caption">
        <small class="copyright__content"
          >&copy; {{ 'now' | date: '%Y' }}, {{ shop.name | link_to: routes.root_url -}} - {{ section.settings.cnpj }} • 
        </small>
        <small class="copyright__content">Desenvolvido por 
          <a href="https://wigcommerce.com.br/?utm_source={{ shop.name }}&utm_medium=desenvolvimento_site" target="_blank">
            WigCommerce
          </a>
        </small>
        {%- if section.settings.show_policy -%}
          <ul class="policies list-unstyled">
            {%- for policy in shop.policies -%}
              {%- if policy != blank -%}
                <li>
                  <small class="copyright__content">
                    <a href="{{ policy.url }}">
                      {{ policy.title | escape }}
                    </a>
                    </small>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>

