{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .bento-gallery-{{ section.id }} {
    --grid-gap: {{ section.settings.grid_gap }}px;
    --grid-gap-mobile: {{ section.settings.grid_gap_mobile }}px;
    --image-border-radius: {{ section.settings.border_radius }}px;
    --title-color: {{ section.settings.title_color }};
    --subtitle-color: {{ section.settings.subtitle_color }};
    --complement-color: {{ section.settings.complement_color }};
  }

  /* Wrapper: mobile / desktop */
  .bento-gallery-{{ section.id }} .bento-gallery__grid-wrapper {
    width: 100%;
    max-width: 400px;
    margin: 0 auto;
  }

  @media screen and (min-width: 750px) {
    .bento-gallery-{{ section.id }} .bento-gallery__grid-wrapper {
      max-width: calc(1191px + var(--grid-gap));
    }
  }

  .bento-gallery-{{ section.id }} .bento-gallery__item {
    position: relative;
    overflow: hidden;
    border-radius: var(--image-border-radius);
    flex-shrink: 0;
  }

  /* Mobile: CSS Grid bento - igual ao layout do usuário */
  @media screen and (max-width: 749px) {
    .bento-gallery-{{ section.id }} .bento-gallery__grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: repeat(5, 1fr);
      column-gap: var(--grid-gap-mobile);
      row-gap: var(--grid-gap-mobile);
      width: 100%;
      aspect-ratio: 4 / 5;
    }
    .bento-gallery-{{ section.id }} .bento-gallery__item:nth-child(1) {
      grid-area: 1 / 1 / 3 / 3;
    }
    .bento-gallery-{{ section.id }} .bento-gallery__item:nth-child(2) {
      grid-area: 1 / 3 / 4 / 5;
    }
    .bento-gallery-{{ section.id }} .bento-gallery__item:nth-child(3) {
      grid-area: 4 / 3 / 6 / 5;
    }
    .bento-gallery-{{ section.id }} .bento-gallery__item:nth-child(4) {
      grid-area: 3 / 1 / 6 / 3;
    }
  }

  /* Desktop: flex layout, 702/1191 e 489/1191 (como estava antes) */
  @media screen and (min-width: 750px) {
    .bento-gallery-{{ section.id }} .bento-gallery__grid {
      display: flex;
      flex-wrap: wrap;
      gap: var(--grid-gap);
    }
    .bento-gallery-{{ section.id }} .bento-gallery__item:nth-child(1),
    .bento-gallery-{{ section.id }} .bento-gallery__item:nth-child(4),
    .bento-gallery-{{ section.id }} .bento-gallery__item:nth-child(4n+5),
    .bento-gallery-{{ section.id }} .bento-gallery__item:nth-child(4n+8) {
      width: calc((100% - var(--grid-gap)) * 0.589);
      height: auto;
      aspect-ratio: 702 / 260;
    }
    .bento-gallery-{{ section.id }} .bento-gallery__item:nth-child(2),
    .bento-gallery-{{ section.id }} .bento-gallery__item:nth-child(3),
    .bento-gallery-{{ section.id }} .bento-gallery__item:nth-child(4n+6),
    .bento-gallery-{{ section.id }} .bento-gallery__item:nth-child(4n+7) {
      width: calc((100% - var(--grid-gap)) * 0.411);
      height: auto;
      aspect-ratio: 489 / 260;
    }
  }

  .bento-gallery-{{ section.id }} .bento-gallery__link {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
  }

  .bento-gallery-{{ section.id }} .bento-gallery__image {
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.image_object_fit }};
    border-radius: var(--image-border-radius);
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .bento-gallery-{{ section.id }} .bento-gallery__image--mobile {
    display: none;
  }

  .bento-gallery-{{ section.id }} .bento-gallery__item:hover .bento-gallery__image {
    transform: scale(1.05);
  }

  .bento-gallery-{{ section.id }} .bento-gallery__header {
    margin-bottom: 3rem;
    text-align: start;
    display: flex;
    align-items: flex-end;
    gap: 105px;
    align-self: stretch;
  }
  .bento-gallery__title strong {
    font-weight: 700;
    line-height: 120%;
    color: #656E52;
  }

  .bento-gallery-{{ section.id }} .bento-gallery__title {
    color: var(--title-color);
  }

  .bento-gallery-{{ section.id }} .bento-gallery__subtitle {
    text-transform: uppercase;
    color: var(--subtitle-color);
    opacity: 0.3;
  }

  @media screen and (max-width: 749px) {
    .bento-gallery-{{ section.id }} .bento-gallery__header {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
    }

    .bento-gallery-{{ section.id }} .bento-gallery__item--has-mobile-image .bento-gallery__image--desktop {
      display: none;
    }

    .bento-gallery-{{ section.id }} .bento-gallery__item--has-mobile-image .bento-gallery__image--mobile {
      display: block;
    }
  }

  @media screen and (min-width: 750px) {
    .bento-gallery-{{ section.id }} .bento-gallery__image--mobile {
      display: none !important;
    }
    .bento-gallery-{{ section.id }} .bento-gallery__image--desktop {
      display: block;
    }
  }

  .bento-gallery-{{ section.id }} .bento-gallery__complement {
    color: var(--complement-color);
    line-height: 140%;
  }

  .bento-gallery__bottom-link {
    display: flex;
    align-items: center;
    gap: 10px;
    color: currentcolor;
    text-decoration: none;
  }
  .bento-gallery-{{ section.id }} .bento-gallery__bottom-link-wrapper {
    margin-top: 4rem;
    text-align: left;
  }

{%- endstyle -%}

<div class="bento-gallery-{{ section.id }} isolate section-{{ section.id }}-padding page-width">
  <div class="">
    {% if section.settings.title_section != blank %}
    <div class="bento-gallery__header">
        <div class="bento-gallery__header-content">
          {% if section.settings.subtitle_section != blank %}
            <p class="bento-gallery__subtitle">{{ section.settings.subtitle_section }}</p>
          {% endif %}
          {% if section.settings.title_section != blank %}
            <h2 class="bento-gallery__title h2">{{ section.settings.title_section }}</h2>
          {% endif %}
        </div>
     
      <div class="bento-gallery__complement-container">
        {% if section.settings.complement_text != blank %}
          <p class="bento-gallery__complement small-text">{{ section.settings.complement_text }}</p>
        {% endif %} 
      </div>
    </div>
    {% endif %}

    {%- if section.blocks.size > 0 -%}
      <div class="bento-gallery__grid-wrapper">
        <div class="bento-gallery__grid">
        {%- for block in section.blocks -%}
          <div class="bento-gallery__item{% if block.settings.image_mobile != blank %} bento-gallery__item--has-mobile-image{% endif %}" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.img_link | default: '#' }}" class="bento-gallery__link">
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 1200
                  | image_tag: loading: 'lazy', class: 'bento-gallery__image bento-gallery__image--desktop', widths: '200, 400, 600, 800, 1000, 1200'
                }}
                {%- if block.settings.image_mobile != blank -%}
                  {{
                    block.settings.image_mobile
                    | image_url: width: 800
                    | image_tag: loading: 'lazy', class: 'bento-gallery__image bento-gallery__image--mobile', widths: '200, 400, 600, 800'
                  }}
                {%- endif -%}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg bento-gallery__image bento-gallery__image--desktop' }}
              {%- endif -%}
            </a>
          </div>
        {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- if section.settings.link_text != blank and section.settings.link_url != blank -%}
      <div class="bento-gallery__bottom-link-wrapper">
        <a href="{{ section.settings.link_url }}" class="bento-gallery__bottom-link description">
          {{- section.settings.link_text -}}
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M4.22806 13.7719C3.92398 13.4679 3.92398 12.9748 4.22806 12.6708L11.3414 5.5574L7.34812 5.5576C6.91808 5.55762 6.56945 5.20903 6.56943 4.77899C6.5694 4.34895 6.918 4.00032 7.34804 4.0003L13.2213 4C13.4278 3.99999 13.6259 4.08203 13.7719 4.22806C13.918 4.3741 14 4.57217 14 4.77869L13.9997 10.652C13.9997 11.082 13.6511 11.4306 13.221 11.4306C12.791 11.4306 12.4424 11.0819 12.4424 10.6519L12.4426 6.65858L5.32924 13.7719C5.02516 14.076 4.53215 14.076 4.22806 13.7719Z" fill="#656E52"/>
          </svg>
        </a>
      </div>
    {%- endif -%}
  </div>
</div>


{% schema %}
    {
        "name": "Galeria Bento",
        "settings": [
            {
                "type": "richtext",
                "id": "title_section",
                "label": "Título da seção",
                "default": "<p>Galeria Bento</p>"
            },
            {
                "type": "color",
                "id": "title_color",
                "label": "Cor do título",
                "default": "#121212"
            },
            {
                "type": "text",
                "id": "subtitle_section",
                "label": "Subtítulo da seção"
            },
            {
                "type": "color",
                "id": "subtitle_color",
                "label": "Cor do subtítulo",
                "default": "#3A3A3A"
            },
            {
                "type": "text",
                "id": "complement_text",
                "label": "Texto complementar"
            },
            {
                "type": "color",
                "id": "complement_color",
                "label": "Cor do texto complementar",
                "default": "#5C5C5C"
            },
            {
                "type": "header",
                "content": "Layout da Galeria"
            },
            {
                "type": "range",
                "id": "grid_gap",
                "min": 0,
                "max": 50,
                "step": 2,
                "unit": "px",
                "label": "Espaçamento entre imagens (desktop)",
                "default": 16
            },
            {
                "type": "range",
                "id": "grid_gap_mobile",
                "min": 0,
                "max": 40,
                "step": 2,
                "unit": "px",
                "label": "Espaçamento entre imagens (mobile)",
                "default": 12
            },
            {
                "type": "range",
                "id": "border_radius",
                "min": 0,
                "max": 50,
                "step": 1,
                "unit": "px",
                "label": "Arredondamento das imagens",
                "default": 12
            },
            {
                "type": "select",
                "id": "image_object_fit",
                "label": "Ajuste da imagem (object-fit)",
                "info": "Define como a imagem preenche o espaço do bloco.",
                "options": [
                    { "value": "cover", "label": "Cobrir (corta para preencher)" },
                    { "value": "contain", "label": "Conter (imagem inteira visível)" },
                    { "value": "fill", "label": "Preencher (pode distorcer)" },
                    { "value": "none", "label": "Nenhum" },
                    { "value": "scale-down", "label": "Reduzir (como contain, mas não aumenta)" }
                ],
                "default": "cover"
            },
            {
                "type": "header",
                "content": "Espaçamento da Seção"
            },
            {
                "type": "range",
                "id": "padding_top",
                "min": 0,
                "max": 100,
                "step": 4,
                "unit": "px",
                "label": "Espaçamento superior (desktop)",
                "default": 36
            },
            {
                "type": "range",
                "id": "padding_bottom",
                "min": 0,
                "max": 100,
                "step": 4,
                "unit": "px",
                "label": "Espaçamento inferior (desktop)",
                "default": 36
            },
            {
                "type": "range",
                "id": "padding_top_mobile",
                "min": 0,
                "max": 80,
                "step": 4,
                "unit": "px",
                "label": "Espaçamento superior (mobile)",
                "default": 28
            },
            {
                "type": "range",
                "id": "padding_bottom_mobile",
                "min": 0,
                "max": 80,
                "step": 4,
                "unit": "px",
                "label": "Espaçamento inferior (mobile)",
                "default": 28
            },
            {
                "type": "header",
                "content": "Link Inferior"
            },
            {
                "type": "text",
                "id": "link_text",
                "label": "Texto do link",
                "default": "Ver todos os projetos"
            },
            {
                "type": "url",
                "id": "link_url",
                "label": "URL do link"
            }
        ],"blocks": [
            {
                "type": "image",
                "name": "Imagem",
                "settings": [
                    {
                        "type": "image_picker",
                        "id": "image",
                        "label": "Imagem (desktop)"
                    },
                    {
                        "type": "image_picker",
                        "id": "image_mobile",
                        "label": "Imagem (mobile)",
                        "info": "Opcional. Se não definir, a imagem de desktop será usada no mobile."
                    },
                    {
                        "type": "url",
                        "id": "img_link",
                        "label": "Link da imagem"
                    }
                ]
            }
        ],"presets": [
          {
            "name": "Galeria Bento"
          }
        ]
    }
{% endschema %}
