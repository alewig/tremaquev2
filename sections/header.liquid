<link rel="stylesheet" href="{{ 'component-list-menu.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-search.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-menu-drawer.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-cart-notification.css' | asset_url }}" media="print" onload="this.media='all'">

{%- if settings.predictive_search_enabled -%}
  <link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

{%- if section.settings.menu_type_desktop == 'mega' -%}
  <link rel="stylesheet" href="{{ 'component-mega-menu.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}


{% if section.settings.show_line_separator == true %}
  <style>
    @media(min-width:989px){
      .header{
          border-bottom: 1px solid {{section.settings.color_border}};
      }
     
    }
    
  </style>
  
{% endif %}

<style>
  /* Override de background conforme solicitado */

  /* Linha de busca (mobile/tablet) também com fundo vermelho */
  .header__mobile-search-row {
    position: relative;
    z-index: 0;
  }

  /* Garantir que o menu drawer fique por cima da busca (mobile) */
  .menu-drawer {
    z-index: 2000 !important;
  }

  .menu-drawer__submenu {
    z-index: 2001 !important;
  }

  .header__icon svg{
    color: {{ section.settings.color_icons }};
  }
  .header__icon--account {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    text-decoration: none;
    
  }
  .header__icon--account .header__account-label {
    margin-left: 0.6rem;
    white-space: nowrap;
  }
  @media screen and (min-width: 990px) {
    .header--two-lines-wrapper .header__icons-wrapper {
      gap: 1.8rem;
    }
    .header--two-lines-wrapper .header__icons-divider,
    .header--two-lines-wrapper .header__icon--favorites,
    .header--two-lines-wrapper .header__icon--cart {
      flex-shrink: 0;
    }
  }
  .search-mobile-toggle svg path {
    stroke: {{ section.settings.color_icons }};
  }
  header-drawer {
    justify-self: start;
    margin-left: -0.5rem;
  }

  {%- if section.settings.sticky_header_type == 'reduce-logo-size' -%}
    .scrolled-past-header .header__heading-logo-wrapper {
      width: 75%;
    }
  {%- endif -%}

  {%- if section.settings.menu_type_desktop != "drawer" -%}
    @media screen and (min-width: 990px) {
      header-drawer {
        display: none;
      }
    }
  {%- else -%}
    /* Se menu_type_desktop for drawer, mostrar drawer em todas as telas */
    header-drawer {
      display: block;
    }
  {%- endif -%}

  .menu-drawer-container {
    display: flex;
  }

  .list-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .list-menu--inline {
    display: inline-flex;
    flex-wrap: wrap;
  }

  summary.list-menu__item {
    padding-right: 2.7rem;
  }

  .list-menu__item {
    display: flex;
    align-items: center;
    line-height: calc(1 + 0.3 / var(--font-body-scale));
  }

  .list-menu__item--link {
    text-decoration: none;
    padding-bottom: 1rem;
    padding-top: 1rem;
    line-height: calc(1 + 0.8 / var(--font-body-scale));
  }
  .desktop-only-search-bar{
    display:none;
  }
  .mobile-only-search-bar-v2{
     display:none;
  }

  .header__mobile-search-row{
    display:none;
    width:100%;
  }

  /* Toggle de busca: só mobile/tablet */
  .header__search-toggle-mobile {
    display: none;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
  }

  /* Ajuste para mobile e tablet: todos os componentes na mesma linha */
  @media(max-width:989px){
    .header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: nowrap;
      position: relative;
      padding-left: 1.5rem !important;
      padding-right: 1.5rem !important;
    }

    .header__standard-contents {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      flex: 1;
      gap: 8px;
      min-width: 0;
    }

    .header__icons {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-shrink: 0;
      flex-wrap: nowrap;
    }

    .header__icon {
      flex-shrink: 0;
      min-width: auto;
    }
    
    /* Busca sempre aberta abaixo do header (mobile/tablet) */
    .header__mobile-search-row{
      display:block;
      padding: 12px 1.5rem 12px;
      box-sizing: border-box;
    }

    .header__mobile-search-row .mobile-only-search-bar-v2{
      display:block;
      width: 100%;
    }

    .header__mobile-search-row .search-container-v2{
      width: 100%;
      max-width: 100%;
      margin: 0;
    }

    .header__mobile-search-row .search-form-v2{
      width: 100% !important;
    }

    /* Garantir que o header-drawer apareça em tablets */
    header-drawer {
      display: block !important;
      flex-shrink: 0;
    }

    /* Garantir que o logo não quebre */
    .header__heading-link {
      flex-shrink: 0;
      min-width: 0;
    }

    .header__heading-logo-wrapper {
      max-width: 100%;
      overflow: hidden;
    }

    .header__heading-logo {
      max-width: 100%;
      height: auto;
    }

    /* Logo igual em todas as páginas: na home está em h1 (line-height:0), fora da home o link herdava line-height e ficava maior */
    .header__standard-contents .header__heading-link {
      line-height: 0;
    }
    .header__standard-contents .header__heading-logo {
      display: block;
      vertical-align: top;
    }
  }
  
  /* Mobile específico: telas muito pequenas */
  @media(max-width:749px){
    .header__mobile-search-row{
      padding: 12px 1rem 12px;
    }
    .header {
      padding-left: 1rem !important;
      padding-right: 1rem !important;
    }
    
    .header__icons {
      gap: 8px;
    }
    
    .header__icon svg {
      width: 20px;
      height: 20px;
    }
  }

  /* Media query específica para tablets (750px - 989px) */
  @media screen and (min-width: 750px) and (max-width: 989px) {
    .header__mobile-search-row{
      padding: 0 2rem 12px;
    }
    .header {
      padding-left: 2rem !important;
      padding-right: 2rem !important;
    }

    /* Forçar exibição do conteúdo padrão em tablets */
    .header__standard-contents {
      display: flex !important;
      gap: 12px;
      align-items: center;
      justify-content: space-between;
      width: 100%;
    }

    .header__icons {
      gap: 12px;
      display: flex;
      align-items: center;
      flex-wrap: nowrap;
      flex-shrink: 0;
    }

    /* Garantir que o menu drawer apareça em tablets */
    header-drawer {
      display: block !important;
      margin-left: 0;
      flex-shrink: 0;
    }

    /* Esconder menus desktop em tablets */
    .header__inline-menu,
    .header__menu,
    header-menu {
      display: none !important;
    }

    /* Garantir que o menu drawer seja visível */
    header-drawer {
      display: block !important;
      visibility: visible !important;
    }

    /* Ajustar tamanho dos ícones se necessário */
    .header__icon {
      flex-shrink: 0;
      min-width: auto;
    }

    .header__icon svg {
      width: 22px;
      height: 22px;
    }

    /* Garantir que o logo não ocupe muito espaço */
    .header__heading-logo-wrapper {
      max-width: 150px;
    }

    .header__heading-link {
      flex-shrink: 0;
    }

    /* Ajustar busca mobile em tablets */
    .mobile-only-search-bar-v2 {
      width: 100%;
      max-width: none;
      flex: 1 1 auto;
      min-width: 0;
    }

    /* Garantir que os elementos não quebrem */
    .header__heading {
      flex-shrink: 0;
      min-width: 0;
    }

    /* Esconder elementos desktop que não devem aparecer em tablets */
    .desktop-only-search-bar {
      display: none !important;
    }

    .mobile-only-search-bar-v2 {
      display: flex !important;
    }

    .header__search-toggle-mobile {
      display: flex;
      align-items: center;
      justify-content: center;
    }
  }
  
  /* Media query para notebooks pequenos (990px - 1440px) */
  @media screen and (min-width: 990px) and (max-width: 1440px) {
    .header {
      padding-left: 2rem !important;
      padding-right: 2rem !important;
    }
    
    .header__icons {
      gap: 15px;
    }
    
  }

  @media screen and (min-width: 750px) {
    .list-menu__item--link {
      padding-bottom: 0.5rem;
      padding-top: 0.5rem;
    }
  }
   @media(min-width:989px){
     .desktop-only-search-bar{
        display:block;
      }
      .mobile-only-search-bar-v2{
        display:none;
      }
      .header__search-toggle-mobile {
        display: none !important;
      }
  }

  /* Two Lines Layout */
  .header--two-lines-wrapper {
    display: block !important;
  }
  
  /* Em tablets, esconder o layout two_lines e mostrar o padrão */
  @media screen and (min-width: 750px) and (max-width: 989px) {
    .header--two-lines-wrapper .header__two-lines-container {
      display: none !important;
    }
    
    .header__standard-contents {
      display: flex !important;
    }
  }

  /* Mobile/tablet: barra de pesquisa some ao rolar para baixo, aparece ao rolar para cima ou no topo */
  @media screen and (max-width: 989px) {
    .header-wrapper .header__mobile-search-row {
      transition: opacity 0.25s ease-out, transform 0.25s ease-out, max-height 0.25s ease-out, padding 0.25s ease-out;
      will-change: opacity, transform;
    }
    .header-wrapper.header--scrolling-down .header__mobile-search-row,
    .header__mobile-search-row.header__second-line--hidden {
      opacity: 0 !important;
      transform: translateY(-100%) !important;
      max-height: 0 !important;
      padding-top: 0 !important;
      padding-bottom: 0 !important;
      pointer-events: none !important;
      overflow: hidden !important;
      visibility: hidden !important;
    }
    .header-wrapper.header--scrolling-up .header__mobile-search-row,
    .header-wrapper:not(.header--scrolled) .header__mobile-search-row,
    .header__mobile-search-row:not(.header__second-line--hidden) {
      opacity: 1;
      transform: translateY(0);
      max-height: 120px;
      pointer-events: auto;
      visibility: visible;
    }
    body.header-second-line-hide .header__mobile-search-row {
      opacity: 0 !important;
      transform: translateY(-100%) !important;
      max-height: 0 !important;
      padding-top: 0 !important;
      padding-bottom: 0 !important;
      pointer-events: none !important;
      visibility: hidden !important;
      overflow: hidden !important;
    }

    /* Mobile/tablet: search bar abre só no topo ou ao clicar no toggle (não ao rolar para cima) */
    body.header__mobile-search--open-by-toggle .header__mobile-search-row {
      opacity: 1 !important;
      transform: translateY(0) !important;
      pointer-events: auto !important;
      visibility: visible !important;
      overflow: visible !important;
    }
  }
  
  @media screen and (min-width: 990px) {
    .header--two-lines-wrapper {
      padding: 0 !important;
    }
    
    .header--two-lines-wrapper .header__two-lines-container {
      display: flex;
      flex-direction: column;
      width: 100%;
      transition: all 0.3s ease;
    }

    .header--two-lines-wrapper .header__top-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 4.3rem;
      transition: background 0.3s ease, backdrop-filter 0.3s ease;
    }

    .header--two-lines-wrapper .header__bottom-row {
      display: flex;
      justify-content: center;
      padding: 10px 3rem;
      transition: opacity 0.2s ease-out, 
                  transform 0.2s ease-out, 
                  max-height 0.2s ease-out, 
                  padding 0.2s ease-out,
                  background 0.2s ease,
                  backdrop-filter 0.2s ease;
      will-change: opacity, transform;
    }

    /* Esconder menu quando rola para BAIXO - !important para não ser sobrescrito por outro CSS */
    .header--two-lines-wrapper.header--scrolling-down .header__bottom-row,
    .header__bottom-row.header__second-line--hidden {
      opacity: 0 !important;
      transform: translateY(-100%) !important;
      max-height: 0 !important;
      padding-top: 0 !important;
      padding-bottom: 0 !important;
      pointer-events: none !important;
      visibility: hidden !important;
      overflow: hidden !important;
    }

    /* Mostrar menu quando rola para CIMA */
    .header--two-lines-wrapper.header--scrolling-up .header__bottom-row {
      opacity: 1;
      transform: translateY(0);
      max-height: 200px;
      pointer-events: auto;
    }
    
    /* No topo da página - menu SEMPRE visível */
    .header--two-lines-wrapper:not(.header--scrolled) .header__bottom-row {
      opacity: 1 !important;
      transform: translateY(0) !important;
      max-height: 200px !important;
      pointer-events: auto !important;
    }

    /* No topo: sem blur */
    .header--two-lines-wrapper:not(.header--scrolled) .header__top-row,
    .header--two-lines-wrapper:not(.header--scrolled) .header__bottom-row {
      background: transparent;
      backdrop-filter: none;
    }

    /* Fallback: classe no body para esconder segunda linha desktop (evita interferência de outro CSS) */
    body.header-second-line-hide .header__bottom-row {
      opacity: 0 !important;
      transform: translateY(-100%) !important;
      max-height: 0 !important;
      padding-top: 0 !important;
      padding-bottom: 0 !important;
      pointer-events: none !important;
      visibility: hidden !important;
      overflow: hidden !important;
    }


    .header--two-lines-wrapper .header__search-wrapper {
      flex: 1;
      display: flex;
      justify-content: center;
      margin: 0 40px;
    }

    .header--two-lines-wrapper .search-container-v2 {
      width: 100%;
      max-width: 640px;
    }

    .header--two-lines-wrapper .search-form-v2 {
      width: 100% !important;
      max-width: none !important;
    }

    .header--two-lines-wrapper .main-container-search-v2 {
      background-color: #F6F6F6;
      border: 1px solid #E7E7E7;
    }
    
    .header--two-lines-wrapper .header__icons-wrapper {
      display: flex;
      gap: 16px;	
      align-items: center;
    }

    .header__icon-recompra {
      display: flex;
      align-items: center;
      gap: 8px;
      text-decoration: none;
      color: #6D6D6D;
      font-size: 16px;
      line-height: 1;
    }
    
    .header--two-lines-wrapper .header__bottom-row .list-menu--inline {
      justify-content: center;
    }
  }
</style>

{%- style -%}
  .header {
    padding: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px 1rem {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px 1rem;
  }

  .section-header {
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  /* Sticky só quando o cabeçalho está em modo sticky (não "nenhum") */
  .section-header:has(> sticky-header) {
    position: sticky;
    top: 0;
    z-index: 3;
  }

  @media screen and (min-width: 750px) {
    .section-header {
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
    
    .header {
      padding-left: 2rem;
      padding-right: 2rem;
    }
  }

  @media screen and (min-width: 990px) {
    .header {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  
  @media screen and (min-width: 1441px) {
    .header {
      padding-left: 3rem;
      padding-right: 3rem;
    }
  }
{%- endstyle -%}

<script src="{{ 'cart-notification.js' | asset_url }}" defer="defer"></script>

{%- liquid
  for block in section.blocks
    if block.type == '@app'
      assign has_app_block = true
    endif
  endfor
-%}

{% liquid
  assign header_tag = 'div'

  if section.settings.sticky_header_type != 'none'
    assign header_tag = 'sticky-header'
  endif
%}

<{{ header_tag }} {% if header_tag == 'sticky-header' %}data-sticky-type="{{ section.settings.sticky_header_type }}"{% endif %} class="header-wrapper color-{{ section.settings.color_scheme }} gradient{% if section.settings.show_line_separator %} header-wrapper--border-bottom{% endif %}">
  {%- liquid
    assign social_links = false
    assign localization_forms = false

    if settings.social_twitter_link != blank or settings.social_facebook_link != blank or settings.social_pinterest_link != blank or settings.social_instagram_link != blank or settings.social_youtube_link != blank or settings.social_vimeo_link != blank or settings.social_tiktok_link != blank or settings.social_tumblr_link != blank or settings.social_snapchat_link != blank
      assign social_links = true
    endif

    if localization.available_countries.size > 1 and section.settings.enable_country_selector or section.settings.enable_language_selector and localization.available_languages.size > 1
      assign localization_forms = true
    endif
  -%}
  <header class="header header--{{ section.settings.logo_position }} header--mobile-{{ section.settings.mobile_logo_position }} page-width{% if section.settings.menu_type_desktop == 'drawer' %} drawer-menu{% endif %}{% if section.settings.menu != blank %} header--has-menu{% endif %}{% if has_app_block %} header--has-app{% endif %}{% if social_links %} header--has-social{% endif %}{% if shop.customer_accounts_enabled %} header--has-account{% endif %}{% if localization_forms %} header--has-localizations{% endif %} {% if section.settings.header_layout == 'two_lines' %}header--two-lines-wrapper{% endif %}">
    
    {%- if section.settings.header_layout == 'two_lines' -%}
      <div class="header__two-lines-container small-hide">
        <div class="header__top-row">
          
          <div class="header__logo-wrapper">
            {%- if request.page_type == 'index' -%}
              <h1 class="header__heading">
            {%- endif -%}
                <a href="{{ routes.root_url }}" class="header__heading-link link link--text focus-inset">
                  {%- if settings.logo != blank -%}
                    {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
                    {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
                    {{ settings.logo | image_url: width: 600 | image_tag:
                      class: 'header__heading-logo motion-reduce',
                      width: settings.logo_width,
                      height: logo_height,
                      alt: logo_alt,
                      preload: true
                    }}
                  {%- else -%}
                    <span class="h2">{{ shop.name }}</span>
                  {%- endif -%}
                </a>
            {%- if request.page_type == 'index' -%}
              </h1>
            {%- endif -%}
          </div>

          <div class="header__search-wrapper">
             {% render 'search-barv2' , input_id: 'Search-Custom-TwoLines' %}
          </div>

          <div class="header__icons-wrapper">

            {%- if shop.customer_accounts_enabled -%}
              <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="header__icon header__icon--account link focus-inset">
                {%- if section.settings.enable_customer_avatar and customer and customer.has_avatar? -%}
                  <account-icon>{{ customer | avatar }}</account-icon>
                {%- else -%}
                  <span class="svg-wrapper">{{ 'icon-account.svg' | inline_asset_content }}</span>
                {%- endif -%}
                <span class="header__account-label small-hide medium-hide">Minha Conta</span>
              </a>
            {%- endif -%}

            <a href="https://seguro.tremaque.com.br/minha-conta/login" class="header__icon header__icon--account link focus-inset small-hide medium-hide" aria-label="Minha Conta">
              <span class="svg-wrapper">{{ 'icon-account.svg' | inline_asset_content }}</span>
              <span class="header__account-label small-hide medium-hide">Minha Conta</span>
            </a>

            <a href="/pages/favoritos" class="header__icon header__icon--favorites link focus-inset small-hide medium-hide" aria-label="Favoritos">
              <span class="svg-wrapper">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M12 6.00019C10.2006 3.90317 7.19377 3.2551 4.93923 5.17534C2.68468 7.09558 2.36727 10.3061 4.13778 12.5772C5.60984 14.4654 10.0648 18.4479 11.5249 19.7369C11.6882 19.8811 11.7699 19.9532 11.8652 19.9815C11.9483 20.0062 12.0393 20.0062 12.1225 19.9815C12.2178 19.9532 12.2994 19.8811 12.4628 19.7369C13.9229 18.4479 18.3778 14.4654 19.8499 12.5772C21.6204 10.3061 21.3417 7.07538 19.0484 5.17534C16.7551 3.2753 13.7994 3.90317 12 6.00019Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
              </span>
            </a>

            <div class="header__icons-divider" style="width: 1px; height: 36px; background-color: #E7E7E7; transform: rotate(15deg);"></div>

            <a href="{{ routes.cart_url }}" class="header__icon header__icon--cart link focus-inset" id="cart-icon-bubble">
              {% if cart == empty %}
                <span class="svg-wrapper">{{'icon-cart-empty.svg' | inline_asset_content }}</span>
              {% else %}
                <span class="svg-wrapper">{{'icon-cart.svg' | inline_asset_content }}</span>
              {% endif %}
              {%- if cart != empty -%}
                <div class="cart-count-bubble">
                  {%- if cart.item_count < 100 -%}
                    <span aria-hidden="true">{{ cart.item_count }}</span>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </a>
          </div>
        </div>
        
        <div class="header__bottom-row">
          {%- if section.settings.menu != blank -%}
            {%- if section.settings.menu_type_desktop == 'dropdown' -%}
              {% render 'header-dropdown-menu' %}
            {%- elsif section.settings.menu_type_desktop != 'drawer' -%}
              {% render 'header-mega-menu' %}
            {%- endif -%}
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    <div class="header__standard-contents {% if section.settings.header_layout == 'two_lines' %}medium-hide large-up-hide{% endif %}">
    {%- liquid
      if section.settings.menu != blank
        render 'header-drawer'
      endif

      if section.settings.logo_position == 'top-center' or section.settings.menu == blank
        render 'header-search', input_id: 'Search-In-Modal-1'
      endif
    -%}

    {%- if section.settings.logo_position != 'middle-center' -%}
      {%- if request.page_type == 'index' -%}
        <h1 class="header__heading">
      {%- endif -%}
          <a href="{{ routes.root_url }}" class="header__heading-link link link--text focus-inset">
            {%- if settings.logo != blank -%}
              <div class="header__heading-logo-wrapper">
                {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
                {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
                {% capture sizes %}(max-width: {{ settings.logo_width | times: 2 }}px) 50vw, {{ settings.logo_width }}px{% endcapture %}
