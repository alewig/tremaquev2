              </div>
            {%- endform -%}
          </localization-form>
        {%- endif -%}
      </div>
      <div class="desktop-only-search-bar">
        {% render 'search-barv2' , input_id: 'Search-Custom-Model-1' %}
       </div>

      <button type="button" class="header__icon header__search-toggle-mobile link focus-inset" aria-label="{{ 'general.search.search' | t }}" aria-expanded="false" data-mobile-search-toggle>
        <span class="svg-wrapper"><svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 22 22" fill="none">
          <path d="M20 20L15.4687 15.4687M17.9167 9.58333C17.9167 14.1857 14.1857 17.9167 9.58333 17.9167C4.98096 17.9167 1.25 14.1857 1.25 9.58333C1.25 4.98096 4.98096 1.25 9.58333 1.25C14.1857 1.25 17.9167 4.98096 17.9167 9.58333Z" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg></span>
      </button>

      {%- if shop.customer_accounts_enabled -%}
        <a
          href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
          class="header__icon header__icon--account link focus-inset"
          rel="nofollow"
        >
          {%- if section.settings.enable_customer_avatar -%}
            <account-icon>
              {%- if customer and customer.has_avatar? -%}
                {{ customer | avatar }}
              {%- else -%}
                <span class="svg-wrapper">{{ 'icon-account.svg' | inline_asset_content }}</span>
              {%- endif -%}
            </account-icon>
          {%- else -%}
            <span class="svg-wrapper">{{ 'icon-account.svg' | inline_asset_content }}</span>
          {%- endif -%}
          <span class="visually-hidden">
            {%- liquid
              if customer
                echo 'customer.account_fallback' | t
              else
                echo 'customer.log_in' | t
              endif
            -%}
          </span>
        </a>
      {%- endif -%}

      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when '@app' -%}
            {% render block %}
        {%- endcase -%}
      {%- endfor -%}

      <a href="{{ routes.cart_url }}" class="header__icon header__icon--cart link focus-inset" id="cart-icon-bubble">
          {% if cart == empty %}
            <span class="svg-wrapper">{{'icon-cart-empty.svg' | inline_asset_content }}</span>
          {% else %}
            <span class="svg-wrapper">{{'icon-cart.svg' | inline_asset_content }}</span>
          {% endif %}
        <span class="visually-hidden">{{ 'templates.cart.cart' | t }}</span>
        {%- if cart != empty -%}
          <div class="cart-count-bubble">
            {%- if cart.item_count < 100 -%}
              <span aria-hidden="true">{{ cart.item_count }}</span>
            {%- endif -%}
            <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
          </div>
        {%- endif -%}
      </a>

    </div>
  </div>

  </header>

  <div class="header__mobile-search-row">
    <div class="mobile-only-search-bar-v2">
      {% render 'search-barv2', input_id: 'Search-Custom-Model-2', always_open: true %}
    </div>
  </div>

</{{ header_tag }}>

{%- if settings.cart_type == "notification" -%}
  {%- render 'cart-notification', color_scheme: section.settings.color_scheme, desktop_menu_type: section.settings.menu_type_desktop -%}
{%- endif -%}

{% javascript %}
class StickyHeader extends HTMLElement {
  constructor() {
    super();
  }

  connectedCallback() {
    this.header =
      this.closest('.section-header') ||
      document.querySelector('.section-header') ||
      this.parentElement;

    if (!this.header) return;

    this.headerIsAlwaysSticky =
      this.getAttribute('data-sticky-type') === 'always' ||
      this.getAttribute('data-sticky-type') === 'reduce-logo-size';

    // ===== ESTADOS IMPORTANTES =====
    this.lastScrollTop =
      window.pageYOffset || document.documentElement.scrollTop;
    this.accumulatedScroll = 0;
    this.headerHidden = false;

    // 👉 estado explícito da segunda linha (FIX DO BUG)
    this.secondLineHidden = false;
    this.lastSecondLineToggleTime = 0;
    this.mobileSearchOpenedByToggleAt = 0;

    this.setHeaderHeight();
    window
      .matchMedia('(max-width: 990px)')
      .addEventListener('change', this.setHeaderHeight.bind(this));

    if (this.headerIsAlwaysSticky) {
      this.header.classList.add('shopify-section-header-sticky');
    }

    this.onScrollHandler = this.onScroll.bind(this);
    window.addEventListener('scroll', this.onScrollHandler, { passive: true });

    this.bindMobileSearchToggle();
    this.onScroll(); // estado inicial
  }

  disconnectedCallback() {
    window.removeEventListener('scroll', this.onScrollHandler);
    var btn = this.querySelector('[data-mobile-search-toggle]');
    if (btn && this._mobileSearchToggleHandler) {
      btn.removeEventListener('click', this._mobileSearchToggleHandler);
    }
  }

  bindMobileSearchToggle() {
    var self = this;
    var btn = this.querySelector('[data-mobile-search-toggle]');
    var mobileRow = this.querySelector('.header__mobile-search-row');
    if (!btn || !mobileRow) return;

    this._mobileSearchToggleHandler = function () {
      if (window.innerWidth >= 990) return;
      var isOpen = document.body.classList.contains('header__mobile-search--open-by-toggle');
      if (isOpen) {
        document.body.classList.remove('header__mobile-search--open-by-toggle');
        mobileRow.classList.add('header__second-line--hidden');
        document.body.classList.add('header-second-line-hide');
        self.secondLineHidden = true;
        btn.setAttribute('aria-expanded', 'false');
      } else {
        document.body.classList.add('header__mobile-search--open-by-toggle');
        mobileRow.classList.remove('header__second-line--hidden');
        document.body.classList.remove('header-second-line-hide');
        self.secondLineHidden = false;
        self.mobileSearchOpenedByToggleAt = Date.now();
        btn.setAttribute('aria-expanded', 'true');
      }
    };
    btn.addEventListener('click', this._mobileSearchToggleHandler);
  }

  setHeaderHeight() {
    if (!this.header) return;
    document.documentElement.style.setProperty(
      '--header-height',
      `${this.header.offsetHeight}px`
    );
  }

  getScrollTop() {
    return window.pageYOffset || document.documentElement.scrollTop;
  }

  onScroll() {
    if (!this.header) return;

    const scrollTop = this.getScrollTop();
    const delta = scrollTop - this.lastScrollTop;
    const width = window.innerWidth;

    const hasTwoLinesDesktop =
      this.querySelector('.header--two-lines-wrapper') && width >= 990;
    const hasSecondLineMobile =
      this.querySelector('.header__mobile-search-row') && width < 990;

    const secondLineMode = hasTwoLinesDesktop || hasSecondLineMobile;

    // ===============================
    // TOPO DA PÁGINA → RESET TOTAL
    // ===============================
    if (scrollTop <= 10) {
      this.headerHidden = false;
      this.accumulatedScroll = 0;

      this.header.classList.remove(
        'shopify-section-header-hidden',
        'shopify-section-header-sticky',
        'scrolled-past-header',
        'animate'
      );

      this.resetSecondLine();
      this.lastScrollTop = scrollTop;
      return;
    }

    // ===============================
    // IGNORA MICRO MOVIMENTOS (ruído)
    // ===============================
    if (Math.abs(delta) < 2) {
      this.lastScrollTop = scrollTop;
      return;
    }

    // ===============================
    // HEADER COM SEGUNDA LINHA
    // ===============================
    if (secondLineMode) {
      this.header.classList.add(
        'shopify-section-header-sticky',
        'scrolled-past-header'
      );
      this.header.classList.remove('shopify-section-header-hidden');

      this.updateSecondLineVisibility(delta);
      this.lastScrollTop = scrollTop;
      return;
    }

    // ===============================
    // HEADER NORMAL (ANTI-FLICKER)
    // ===============================
    this.accumulatedScroll += delta;

    // ↓ ESCONDER
    if (!this.headerHidden && this.accumulatedScroll > 20) {
      if (!this.headerIsAlwaysSticky) {
        this.headerHidden = true;
        this.accumulatedScroll = 0;

        this.header.classList.add(
          'shopify-section-header-hidden',
          'shopify-section-header-sticky',
          'scrolled-past-header'
        );

        this.closeMenuDisclosure();
        this.closeSearchModal();
      }
    }

    // ↑ MOSTRAR
    if (this.headerHidden && this.accumulatedScroll < -12) {
      this.headerHidden = false;
      this.accumulatedScroll = 0;

      this.header.classList.remove('shopify-section-header-hidden');
      this.header.classList.add(
        'shopify-section-header-sticky',
        'scrolled-past-header',
        'animate'
      );
    }

    this.lastScrollTop = scrollTop;
  }

  // ===============================
  // SEGUNDA LINHA (desktop / mobile)
  // ===============================
  updateSecondLineVisibility(delta) {
    const deltaToToggle = 8;
    const cooldownMs = 120;
    const now = Date.now();

    if (now - this.lastSecondLineToggleTime < cooldownMs) return;
    if (Math.abs(delta) < deltaToToggle) return;

    const twoLines = this.querySelector('.header--two-lines-wrapper');
    const bottomRow = this.querySelector('.header__bottom-row');
    const mobileRow = this.querySelector('.header__mobile-search-row');
    const width = window.innerWidth;

    // ===== DESKTOP =====
    if (width >= 990 && twoLines && bottomRow) {
      twoLines.classList.add('header--scrolled');

      if (delta > 0 && !this.secondLineHidden) {
        this.secondLineHidden = true;
        bottomRow.classList.add('header__second-line--hidden');
        document.body.classList.add('header-second-line-hide');
        this.lastSecondLineToggleTime = now;
      }

      if (delta < 0 && this.secondLineHidden) {
        this.secondLineHidden = false;
        bottomRow.classList.remove('header__second-line--hidden');
        document.body.classList.remove('header-second-line-hide');
        this.lastSecondLineToggleTime = now;
      }
    }

    // ===== MOBILE/TABLET =====
    // Só esconde ao rolar para baixo; não reabre ao rolar para cima (abre só no topo ou pelo toggle).
    // Se a barra foi aberta pelo toggle, NÃO fechar por scroll (só fecha ao clicar no toggle de novo).
    if (width < 990 && mobileRow) {
      this.classList.add('header--scrolled');

      if (delta > 0 && !this.secondLineHidden) {
        var justOpened = (now - this.mobileSearchOpenedByToggleAt) < 400;
        if (!justOpened) {
          this.secondLineHidden = true;
          mobileRow.classList.add('header__second-line--hidden');
          document.body.classList.add('header-second-line-hide');
          document.body.classList.remove('header__mobile-search--open-by-toggle');
          this.lastSecondLineToggleTime = now;
        }
      }
    }
  }

  resetSecondLine() {
    const twoLines = this.querySelector('.header--two-lines-wrapper');
    const bottomRow = this.querySelector('.header__bottom-row');
    const mobileRow = this.querySelector('.header__mobile-search-row');

    this.secondLineHidden = false;

    if (twoLines) twoLines.classList.remove('header--scrolled');
    if (bottomRow) bottomRow.classList.remove('header__second-line--hidden');
    if (mobileRow) mobileRow.classList.remove('header__second-line--hidden');

    document.body.classList.remove('header-second-line-hide');
    document.body.classList.remove('header__mobile-search--open-by-toggle');

    var toggleBtn = this.querySelector('[data-mobile-search-toggle]');
    if (toggleBtn) toggleBtn.setAttribute('aria-expanded', 'false');
  }

  closeMenuDisclosure() {
    const disclosures = this.header.querySelectorAll('header-menu');
    disclosures.forEach((d) => d.close());
  }

  closeSearchModal() {
    const searchModal = this.header.querySelector('details-modal');
    if (searchModal) searchModal.close(false);
  }
}

customElements.define('sticky-header', StickyHeader);
{% endjavascript %}




