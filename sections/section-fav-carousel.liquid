{% comment %}
  Carrossel de produtos favoritos (localStorage do tools.liquid).
  Estilo alinhado ao collections-carrousel-v2.
{% endcomment %}

{%- liquid
  assign section_title = section.settings.title | default: 'Seus Favoritos'
  assign section_title_color = section.settings.title_color | default: '#4f4f4f'
  assign title_size_desktop = section.settings.title_size_desktop | default: 40
  assign title_size_mobile = section.settings.title_size_mobile | default: 32
  assign section_background_color = section.settings.background_color | default: ''
  assign view_all_text = section.settings.view_all_text | default: 'Ver todos'
  assign view_all_url = section.settings.view_all_url | default: ''
  assign view_all_text_color = section.settings.view_all_text_color | default: '#6d6d6d'
  assign view_all_arrow_color = section.settings.view_all_arrow_color | default: '#6d6d6d'
  assign view_all_arrow_bg = section.settings.view_all_arrow_background_color | default: ''
  assign padding_top = section.settings.padding_top | default: 40
  assign padding_bottom = section.settings.padding_bottom | default: 40
  assign space_between = section.settings.space_between | default: 32
-%}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

<section
  class="fav-carousel-{{ section.id }}"
  id="fav-carousel-section-{{ section.id }}"
  data-section-id="{{ section.id }}"
  style="padding-top: {{ padding_top }}px; padding-bottom: {{ padding_bottom }}px;{% if section_background_color != blank %} background-color: {{ section_background_color }};{% endif %}"
>
  <div class="page-width">
    <div class="fav-carousel__header-{{ section.id }}">
      {%- if section_title != blank -%}
        <h2 class="fav-carousel__title-{{ section.id }}" style="color: {{ section_title_color }};">
          {{ section_title }}
        </h2>
      {%- endif -%}
      {%- if view_all_url != blank -%}
        <a href="{{ view_all_url }}" class="fav-carousel__view-all-{{ section.id }}">
          <span class="fav-carousel__view-all-text-{{ section.id }}">{{ view_all_text }}</span>
          <div class="fav-carousel__view-all-icon-wrapper-{{ section.id }}"{% if view_all_arrow_bg != blank %} style="background-color: {{ view_all_arrow_bg }};"{% endif %}>
            <svg class="fav-carousel__view-all-icon-{{ section.id }}" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </a>
      {%- endif -%}
    </div>

    <div class="fav-carousel__wrap-{{ section.id }}">
      <p class="fav-carousel__loading-{{ section.id }}" data-fav-loading>Carregando favoritos...</p>
      <div class="fav-carousel__empty-{{ section.id }}" data-fav-empty hidden>
        <p>{{ section.settings.empty_message | default: 'Você ainda não tem produtos favoritos. Adicione clicando no coração na página do produto.' }}</p>
      </div>
      <div class="fav-carousel__slider-{{ section.id }} swiper" data-fav-slider hidden>
        <div class="swiper-wrapper" data-fav-wrapper></div>
      </div>
    </div>
  </div>
</section>

<style>
  .fav-carousel-{{ section.id }} { width: 100%; }
  .fav-carousel__header-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 40px;
    width: 100%;
  }
  .fav-carousel__title-{{ section.id }} {
    font-size: {{ title_size_desktop }}px;
    font-weight: 700;
    line-height: 1.2;
    margin: 0;
  }
  .fav-carousel__view-all-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }
  .fav-carousel__view-all-{{ section.id }}:hover { opacity: 0.7; }
  .fav-carousel__view-all-text-{{ section.id }} {
    font-size: 18px;
    font-weight: 400;
    line-height: 1.4;
    white-space: nowrap;
    color: {{ view_all_text_color }};
  }
  .fav-carousel__view-all-icon-wrapper-{{ section.id }} {
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .fav-carousel__view-all-icon-{{ section.id }} {
    width: 21px;
    height: 21px;
    color: {{ view_all_arrow_color }};
  }
  .fav-carousel__loading-{{ section.id }},
  .fav-carousel__empty-{{ section.id }} {
    text-align: center;
    padding: 40px 20px;
    color: #4F4F4F;
    margin: 0;
  }
  .fav-carousel__slider-{{ section.id }} {
    width: 100%;
    overflow: hidden;
  }
  .fav-carousel__slider-{{ section.id }} .swiper-wrapper {
    display: flex;
    align-items: stretch;
  }
  .fav-carousel__slider-{{ section.id }} .swiper-slide {
    height: auto;
    display: flex;
    align-items: stretch;
    box-sizing: border-box;
    flex-shrink: 0;
    width: 280px !important;
    max-width: 280px !important;
  }
  .fav-carousel__slider-{{ section.id }} .swiper-slide > * { width: 100%; }
  .fav-carousel__slider-{{ section.id }} .swiper-slide .fav-card-wrapper,
  .fav-carousel__slider-{{ section.id }} .swiper-slide .product-card-new {
    width: 100%;
    max-width: 100%;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .fav-carousel__slider-{{ section.id }} .swiper-slide .product-card-new__image-wrapper {
    width: 100%;
    height: 280px;
  }
  @media (max-width: 749px) {
    .fav-carousel__title-{{ section.id }} { font-size: {{ title_size_mobile }}px; }
    .fav-carousel__header-{{ section.id }} {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }
  }
</style>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>
<script>
  (function () {
    var sectionId = {{ section.id | json }};
    var sectionEl = document.getElementById('fav-carousel-section-' + sectionId);
    if (!sectionEl) return;

    var loadingEl = sectionEl.querySelector('[data-fav-loading]');
    var emptyEl = sectionEl.querySelector('[data-fav-empty]');
    var sliderEl = sectionEl.querySelector('[data-fav-slider]');
    var wrapperEl = sectionEl.querySelector('[data-fav-wrapper]');
    var spaceBetween = {{ space_between }};

    var SECTION_CARD_ID = 'fav-card';

    function getFavoritos() {
      if (window.TremaqueFavoritos && typeof window.TremaqueFavoritos.get === 'function')
        return window.TremaqueFavoritos.get();
      try {
        var raw = localStorage.getItem('tremaque_favoritos');
        return raw ? JSON.parse(raw) : [];
      } catch (e) {
        return [];
      }
    }

    function buildSlideFromHtml(html) {
      var slide = document.createElement('div');
      slide.className = 'swiper-slide';
      slide.innerHTML = html;
      return slide;
    }

    function destroySwiper() {
      if (sliderEl && sliderEl.swiper) {
        sliderEl.swiper.destroy(true, true);
        sliderEl.swiper = null;
      }
    }

    function initSwiper() {
      if (!sliderEl || !wrapperEl || typeof Swiper === 'undefined') return;
      if (sliderEl.swiper) return;
      sliderEl.swiper = new Swiper(sliderEl, {
        slidesPerView: 'auto',
        spaceBetween: spaceBetween,
        grabCursor: true,
        watchOverflow: true,
        freeMode: false,
        centeredSlides: false
      });
    }

    function render() {
      var handles = getFavoritos();
      if (loadingEl) loadingEl.hidden = true;
      if (emptyEl) emptyEl.hidden = true;
      if (sliderEl) sliderEl.hidden = true;

      if (handles.length === 0) {
        if (emptyEl) emptyEl.hidden = false;
        destroySwiper();
        return;
      }

      if (!wrapperEl) return;
      wrapperEl.innerHTML = '';
      var done = 0;
      handles.forEach(function (handle) {
        fetch('/products/' + encodeURIComponent(handle) + '?section_id=' + encodeURIComponent(SECTION_CARD_ID))
          .then(function (res) { return res.ok ? res.text() : null; })
          .then(function (html) {
            if (html && html.trim()) {
              wrapperEl.appendChild(buildSlideFromHtml(html));
            }
            done++;
            if (done === handles.length) {
              if (wrapperEl.children.length === 0) {
                if (emptyEl) emptyEl.hidden = false;
                destroySwiper();
              } else {
                if (sliderEl) sliderEl.hidden = false;
                destroySwiper();
                setTimeout(initSwiper, 50);
              }
            }
          })
          .catch(function () {
            done++;
            if (done === handles.length) {
              if (wrapperEl.children.length === 0 && emptyEl) emptyEl.hidden = false;
              else {
                if (sliderEl) sliderEl.hidden = false;
                destroySwiper();
                setTimeout(initSwiper, 50);
              }
            }
          });
      });
    }

    function waitSwiper() {
      if (typeof Swiper !== 'undefined') {
        render();
      } else {
        setTimeout(waitSwiper, 50);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', waitSwiper);
    } else {
      waitSwiper();
    }

    window.addEventListener('tremaque-favoritos-changed', function () {
      render();
    });

    if (window.Shopify && window.Shopify.designMode) {
      document.addEventListener('shopify:section:load', waitSwiper);
      document.addEventListener('shopify:section:reorder', waitSwiper);
      document.addEventListener('shopify:section:select', waitSwiper);
      document.addEventListener('shopify:section:deselect', waitSwiper);
      document.addEventListener('shopify:section:unload', destroySwiper);
    }
  })();
</script>

{% schema %}
{
  "name": "Carousel Favoritos",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Seus Favoritos"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Cor do título",
      "default": "#4f4f4f"
    },
    {
      "type": "range",
      "id": "title_size_desktop",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Tamanho do título (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Tamanho do título (Mobile)",
      "default": 32
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Cor de fundo da seção"
    },
    {
      "type": "header",
      "content": "Botão Ver todos"
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "Texto do botão",
      "default": "Ver todos"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "Link do botão",
      "info": "Ex.: página de favoritos. Deixe em branco para ocultar."
    },
    {
      "type": "color",
      "id": "view_all_text_color",
      "label": "Cor do texto",
      "default": "#6d6d6d"
    },
    {
      "type": "color",
      "id": "view_all_arrow_color",
      "label": "Cor da seta",
      "default": "#6d6d6d"
    },
    {
      "type": "color",
      "id": "view_all_arrow_background_color",
      "label": "Cor de fundo do círculo da seta"
    },
    {
      "type": "header",
      "content": "Lista vazia"
    },
    {
      "type": "textarea",
      "id": "empty_message",
      "label": "Mensagem quando não houver favoritos",
      "default": "Você ainda não tem produtos favoritos. Adicione clicando no coração na página do produto."
    },
    {
      "type": "header",
      "content": "Espaçamento"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding superior",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding inferior",
      "default": 40
    },
    {
      "type": "range",
      "id": "space_between",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Espaçamento entre cards",
      "default": 32
    }
  ],
  "presets": [
    {
      "name": "Carousel Favoritos"
    }
  ]
}
{% endschema %}
