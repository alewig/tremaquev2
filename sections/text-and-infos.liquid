        },
        {
          "type": "text",
          "id": "item_value",
          "label": "Item Value",
          "default": "Califórnia, EUA"
        },
        {
          "type": "url",
          "id": "item_link",
          "label": "Item Link",
          "info": "Optional: If provided, the value will be a clickable link"
