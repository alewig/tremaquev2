{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .tip-container-{{ section.id }} {
    background-color: {{ section.settings.color_bg }};
    border: 1.6px dashed {{ section.settings.color_border }};
    border-radius: 16px;
    padding: 25px 33px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
  }

  .tip-content-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .tip-header-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .tip-icon-{{ section.id }} {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .tip-icon-{{ section.id }} img,
  .tip-icon-{{ section.id }} svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .tip-title-{{ section.id }} {
    font-weight: 700;
    font-size: 24px;
    line-height: 28px;
    color: {{ section.settings.color_title }};
    margin: 0;
  }

  .tip-description-{{ section.id }} {
    font-weight: 400;
    font-size: 16px;
    line-height: 24px;
    color: {{ section.settings.color_description }};
    margin: 0;
  }

  .tip-button-{{ section.id }} {
    background-color: {{ section.settings.color_button_bg }};
    color: {{ section.settings.color_button_text }};
    border-radius: 8px;
    padding: 16px 20px;
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    transition: opacity 0.3s ease;
    flex-shrink: 0;
  }

  .tip-button-{{ section.id }}:hover {
    opacity: 0.9;
  }

  .tip-button-text-{{ section.id }} {
    font-size: 16px;
    line-height: 24px;
  }

  .tip-button-icon-{{ section.id }} {
    width: 29px;
    height: 20px;
    display: flex;
    align-items: center;
  }
  
  .tip-button-icon-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  @media screen and (max-width: 768px) {
    .tip-container-{{ section.id }} {
      flex-direction: column;
      align-items: flex-start;
      padding: 20px;
    }
    
    .tip-button-{{ section.id }} {
      width: 100%;
      justify-content: center;
    }
  }
{%- endstyle -%}

<div class="page-width section-{{ section.id }}-padding">
  <div class="tip-container-{{ section.id }}">
    <div class="tip-content-{{ section.id }}">
      <div class="tip-header-{{ section.id }}">
        {%- if section.settings.icon != blank -%}
          <div class="tip-icon-{{ section.id }}">
            {{ section.settings.icon | image_url: width: 80 | image_tag: loading: 'lazy' }}
          </div>
        {%- else -%}
           <!-- Icone padrão (exemplo SVG) -->
           <div class="tip-icon-{{ section.id }}">
             <svg width="27" height="27" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
               <rect x="3" y="3" width="18" height="18" rx="2" stroke="#D6002A" stroke-width="2"/>
               <path d="M7 12L10 15L17 8" stroke="#D6002A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
             </svg>
           </div>
        {%- endif -%}
        
        <h3 class="tip-title-{{ section.id }}">
          {{ section.settings.title }}
        </h3>
      </div>
      
      {%- if section.settings.description != blank -%}
        <p class="tip-description-{{ section.id }}">
          {{ section.settings.description | escape }}
        </p>
      {%- endif -%}
    </div>

    <a href="{{ section.settings.button_link }}" class="tip-button-{{ section.id }}">
      <span class="tip-button-text-{{ section.id }}">
        {{ section.settings.button_text }}
      </span>
      {%- if section.settings.button_icon != blank -%}
        <div class="tip-button-icon-{{ section.id }}">
          {{ section.settings.button_icon | image_url: width: 60 | image_tag: loading: 'lazy' }}
        </div>
      {%- else -%}
        <!-- Icone Youtube padrão -->
        <div class="tip-button-icon-{{ section.id }}">
           <svg width="29" height="20" viewBox="0 0 29 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M28.4 3.2C28.1 1.9 27.1 0.9 25.8 0.6C23.5 0 14.5 0 14.5 0C14.5 0 5.5 0 3.2 0.6C1.9 0.9 0.9 1.9 0.6 3.2C0 5.5 0 10.3 0 10.3C0 10.3 0 15.1 0.6 17.4C0.9 18.7 1.9 19.7 3.2 20C5.5 20.6 14.5 20.6 14.5 20.6C14.5 20.6 23.5 20.6 25.8 20C27.1 19.7 28.1 18.7 28.4 17.4C29 15.1 29 10.3 29 10.3C29 10.3 29 5.5 28.4 3.2Z" fill="white"/>
            <path d="M11.6 14.7L19.1 10.3L11.6 5.9V14.7Z" fill="{{ section.settings.color_button_bg }}"/>
           </svg>
        </div>
      {%- endif -%}
    </a>
  </div>
</div>

{% schema %}
{
  "name": "Tip Box",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Layout e Cores"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Cor de Fundo",
      "default": "#FFF0F3"
    },
    {
      "type": "color",
      "id": "color_border",
      "label": "Cor da Borda",
      "default": "#FFDDE4"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Superior",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Inferior",
      "default": 36
    },
    {
      "type": "header",
      "content": "Conteúdo Esquerdo"
    },
    {
      "type": "image_picker",
      "id": "icon",
      "label": "Ícone"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Título",
      "default": "Veja como faturar"
    },
    {
      "type": "color",
      "id": "color_title",
      "label": "Cor do Título",
      "default": "#5D5D5D"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Descrição",
      "default": "Acesso gratuito ao mini-curso com receitas, dicas e estratégias de venda"
    },
    {
      "type": "color",
      "id": "color_description",
      "label": "Cor da Descrição",
      "default": "#6D6D6D"
    },
    {
      "type": "header",
      "content": "Botão (Direita)"
    },
    {
      "type": "inline_richtext",
      "id": "button_text",
      "label": "Texto do Botão",
      "default": "Acessar os cursos do <strong>Youtube</strong>"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Link do Botão"
    },
    {
      "type": "image_picker",
      "id": "button_icon",
      "label": "Ícone do Botão (Opcional)"
    },
    {
      "type": "color",
      "id": "color_button_bg",
      "label": "Fundo do Botão",
      "default": "#D6002A"
    },
    {
      "type": "color",
      "id": "color_button_text",
      "label": "Texto do Botão",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "Tip Box"
    }
  ]
}
{% endschema %}

