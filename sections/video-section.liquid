<div class="spacer-{{ section.id }}-top">&nbsp;</div>
<script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
<div class="main-video-carrousel-{{ section.id }} page-width">
    {% if section.settings.title_section %}
        <h2 class="title-section-{{ section.id }}" style="font-size: {{ section.settings.font_size_title }}px;">{{ section.settings.title_section }}</h2>
    {% endif %}
    
    <div class="swiper-container-{{ section.id }}" id="video-swiper-{{ section.id }}">
        <div class="swiper-wrapper">
            {% for block in section.blocks %}
                <div class="swiper-slide" 
                     data-section-id="{{ section.id }}"
                     data-product-handle="{% if block.settings.product_link_video %}{{ block.settings.product_link_video.handle }}{% endif %}"
                     data-product-title="{% if block.settings.product_link_video %}{{ block.settings.product_link_video.title | escape }}{% endif %}"
                     data-product-url="{% if block.settings.product_link_video %}{{ block.settings.product_link_video.url }}{% endif %}"
                    >
                     
                    <div class="wrapper-video-block-{{ section.id }}">
                        {{ block.settings.video_url | video_tag:
                            image_size: '600x',
                            autoplay: false,
                            loop: false,
                            controls: false,
                            muted: false,
                            playsinline: true
                        }}
                        <button class="play-button" aria-label="Abrir vídeo em modal"></button>
                    </div>
                </div>
            {% endfor %}
        </div>

        <div class="swiper-pagination-{{ section.id }}"></div>
        <div class="swiper-button-prev-{{ section.id }}"></div>
        <div class="swiper-button-next-{{ section.id }}"></div>
    </div>
</div>

<div class="spacer-{{ section.id }}-bottom">&nbsp;</div>

{% comment %} Inicialização do Swiper com escopo único e proteções {% endcomment %}
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Verifica se já foi inicializado
        var container = document.getElementById('video-swiper-{{ section.id }}');
        if (!container || container.dataset.swiperInitialized === 'true') return;
        
        // Aguarda o Swiper estar disponível
        function initVideoSwiper() {
            if (typeof Swiper === 'undefined') {
                setTimeout(initVideoSwiper, 100);
                return;
            }
            
            try {
                var swiper = new Swiper(container, {
                    slidesPerView: 1.3,
                    spaceBetween: 16,
                    loop: false,
                    autoplay: { 
                        delay: 5000, 
                        disableOnInteraction: false 
                    },
                    breakpoints: { 
                        640: { slidesPerView: 2 }, 
                        1024: { slidesPerView: 4 } 
                    },
                    on: {
                        init: function() {
                            container.dataset.swiperInitialized = 'true';
                        }
                    }
                });
                
                // Armazena a instância para possível destruição
                container.swiperInstance = swiper;
                
            } catch (error) {
                console.warn('Erro ao inicializar Swiper para seção {{ section.id }}:', error);
            }
        }
        
        // Inicializa quando o DOM estiver pronto
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initVideoSwiper);
        } else {
            initVideoSwiper();
        }
    });
    
    // Cleanup quando a seção for removida (para o editor do Shopify)
    if (Shopify.designMode) {
        document.addEventListener('shopify:section:unload', function(event) {
            if (event.detail.sectionId === '{{ section.id }}') {
                var container = document.getElementById('video-swiper-{{ section.id }}');
                if (container && container.swiperInstance) {
                    try {
                        container.swiperInstance.destroy(true, true);
                        container.swiperInstance = null;
                        container.dataset.swiperInitialized = '';
                    } catch(e) {
                        console.warn('Erro ao destruir Swiper:', e);
                    }
                }
            }
        });
    }
</script>

{% style %}
.spacer-{{ section.id }}-top{
        padding-top: {{ section.settings.padding_space }}px;
    }
    .spacer-{{ section.id }}-bottom{
        padding-bottom: {{ section.settings.padding_space }}px;
    }
    @media (max-width: 749px){
        .spacer-{{ section.id }}-top{
            padding-top: {{ section.settings.padding_space_mobile }}px;
        }
        .spacer-{{ section.id }}-bottom{
            padding-bottom: {{ section.settings.padding_space_mobile }}px;
        }
    }
    .swiper-container-{{ section.id }}{
        overflow: hidden;
    }
    .main-video-carrousel-{{ section.id }} .title-section-{{ section.id }} {
        text-align: center;
        margin-bottom: 40px;
        font-weight: {{ section.settings.peso_fonte_title }};

    }
    
    .wrapper-video-block-{{ section.id }} {
        position: relative;
        width: {{ section.settings.width_video }}px;
        height: {{ section.settings.height_video }}px;
        border-radius: {{ section.settings.border_radius_videos }}px;
        overflow: hidden;
        pointer-events: none;
    }
    
    .main-video-carrousel-{{ section.id }} .wrapper-video-block-{{ section.id }} video {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    
    .main-video-carrousel-{{ section.id }} .wrapper-video-block-{{ section.id }} .play-button {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 50px;
        height: 60px;
        background-color: {{ section.settings.background_play_button }};
        border-radius: 50%;
        cursor: pointer;
        z-index: 10;
        border: none;
        outline: none;
        pointer-events: auto;
    }
    
    .main-video-carrousel-{{ section.id }} .wrapper-video-block-{{ section.id }} .play-button::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 55%;
        transform: translate(-50%, -50%);
        width: 0;
        height: 0;
        border-top: 15px solid transparent;
        border-bottom: 15px solid transparent;
        border-left: 20px solid white;
    }
    
    .main-video-carrousel-{{ section.id }} .swiper-slide {
        display: flex;
        align-items: center;
        width: {{ section.settings.width_video }}px !important;
    }
    
    /* Estilos específicos para navegação e paginação desta seção */
    .main-video-carrousel-{{ section.id }} .swiper-button-prev-{{ section.id }},
    .main-video-carrousel-{{ section.id }} .swiper-button-next-{{ section.id }} {
        color: #333;
        background: rgba(255, 255, 255, 0.8);
        border-radius: 50%;
        width: 40px;
        height: 40px;
    }
    
    .main-video-carrousel-{{ section.id }} .swiper-pagination-{{ section.id }} .swiper-pagination-bullet {
        background: #333;
        opacity: 0.5;
    }
    
    .main-video-carrousel-{{ section.id }} .swiper-pagination-{{ section.id }} .swiper-pagination-bullet-active {
        opacity: 1;
    }
    
    @media(min-width: 890px) {
        .main-video-carrousel-{{ section.id }} .swiper-wrapper {
            /* Estilos específicos para desktop se necessário */
        }
    }
{% endstyle %}

{% schema %}
    {
        "name": "Carrousel Videos",
        "settings": [
            {
                "type": "number",
                 "id":"padding_space",
                 "label": "Padding Space",
                 "default": 50
            },
            {
                "type": "number",
                 "id":"padding_space_mobile",
                 "label": "Padding Space Mobile",
                 "default": 30
            },
            {
                "type": "text",
                "id": "title_section",
                "label": "Titulo da seção"
            },
            {
                "type": "number",
                "id": "font_size_title",
                "label": "Tamanho da fonte (Titulo)",
                "default": 40
            },
            {
                "type": "number",
                "id": "border_radius_videos",
                "label": "Arredondamento Borda",
                "default": 12
            },
            {
                "type": "color",
                "id": "background_play_button",
                "label": "Cor de fundo do botão play",
                "default": "#FE68A099"
            },
            {
                "type": "number",
                "id": "width_video",
                "label": "Largura video",
                "default": 230
            },
            {
                "type": "number",
                "id": "height_video",
                "label": "Altura video",
                "default": 408
            },
            {
                "type": "number",
                "id": "peso_fonte_title",
                "label": "Peso da fonte",
                "default": 700
            }
        ],
        "blocks": [
            {
                "type": "video",
                "name": "video",
                "settings": [
                    {
                        "type": "video",
                        "id": "video_url",
                        "label": "Video"
                    },
                    {
                        "type": "product",
                        "id": "product_link_video",
                        "label": "Produto vinculado ao video"
                    }
                ]
            }
        ],
        "presets": [
            {
                "name": "Carrousel Videos"
            }
        ]
    }
{% endschema %}