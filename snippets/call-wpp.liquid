{%- liquid
  assign wpp_product = product
  if wpp_product == blank
    assign wpp_product = card_product
  endif

  if wpp_product != blank and settings.number_contato != blank
    assign product_title = wpp_product.title
    assign product_url = shop.url | append: wpp_product.url

    # Template message (priority): mensagem_produto > mensagem_padrao (legacy) > hardcoded default
    assign message_template = settings.mensagem_produto
    if message_template == blank
      assign message_template = settings.mensagem_padrao
    endif
    if message_template == blank
      assign message_template = 'Gostaria de saber mais sobre\n{product_title}\n{product_url}'
    endif

    assign page_url = request.origin | append: request.path

    assign whatsapp_message = message_template | replace: '{product_title}', product_title | replace: '{product_url}', product_url | replace: '{shop_name}', shop.name | replace: '{page_url}', page_url | url_encode

    assign whatsapp_number = settings.number_contato | remove: ' ' | remove: '-' | remove: '(' | remove: ')' | remove: '.'
    assign whatsapp_link = 'https://wa.me/' | append: whatsapp_number | append: '?text=' | append: whatsapp_message
  endif
-%}

{%- if whatsapp_link != blank -%}
  <a href="{{ whatsapp_link }}" class="call-wpp-container" target="_blank" rel="noopener noreferrer" aria-label="Falar no WhatsApp sobre {{ product_title | escape }}">
{%- else -%}
  <div class="call-wpp-container">
{%- endif -%}
