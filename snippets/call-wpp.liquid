      <h2 class="title-call-wpp">FALAR NO WHATSAPP</h2>
{%- if whatsapp_link != blank -%}
  </a>
{%- else -%}
  </div>
{%- endif -%}

<style>
    .title-call-wpp{
        color: var(--gray-700, #4F4F4F);
        leading-trim: both;
        text-edge: cap;
        font-size: 16px;
        font-style: normal;
        font-weight: 600;
        line-height: normal;
        text-transform: uppercase;
    }
    .call-wpp-container svg{
        width: 30px;
        height: 30px;
    }
    .call-wpp-container{
        display: flex;
        padding: 16px 20px;
        justify-content: center;
        align-items: center;
        gap: 8px;
        border-radius: 8px;
        background: #CEFFE1;
        white-space: nowrap;
        flex-shrink: 0;
        min-height: calc(4.5rem + var(--buttons-border-width) * 2);
        text-decoration: none;
        transition: opacity 0.3s ease;
        cursor: pointer;
    }
    a.call-wpp-container:hover {
        opacity: 0.9;
    }
    @media (max-width: 1100px){
      .title-call-wpp{  
        display: none;
      }
    }
</style>