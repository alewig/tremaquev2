{% comment %}
  Renders product variant options

  Accepts:
  - product: {Object} product object.
  - option: {Object} current product_option object.
  - block: {Object} block object.


  Usage:
  {% render 'product-variant-options',
    product: product,
    option: option,
    block: block
  %}
{% endcomment %}
{%- liquid
  assign variants_available_arr = product.variants | map: 'available'
  assign variants_option1_arr = product.variants | map: 'option1'
  assign variants_option2_arr = product.variants | map: 'option2'
  assign variants_option3_arr = product.variants | map: 'option3'

  assign product_form_id = 'product-form-' | append: section.id

  assign swatchType = settings.swatchType
  assign swatchStyle = settings.swatchStyle
  assign swatchSize = settings.swatchSize
  assign swatchColors = settings.swatchColors | newline_to_br | split: '<br />'

  assign custo_beneficio_index = product.metafields.custom.index_custo_beneficio.value
  assign em_alta_index = product.metafields.custom.index_em_alta.value 

-%}

<style>

{% comment %} ANIMAÇÕES {% endcomment %}

.product-form__input input[type='radio'] + label.color-swatch,
.product-form__input input[type='radio'] + label.color-swatch::before,
.product-form__input input[type='radio'] + label.color-swatch::after {
  transition:
    transform 0.4s ease,
    box-shadow 0.4s ease,
    background-color 0.4s ease,
    border-color 0.4s ease,
    opacity 0.4s ease;
  will-change: transform, box-shadow, opacity;
  transform: translateZ(0); /* força GPU, evita “saltos” */
  backface-visibility: hidden;
}

.variant-options-grid label.color-swatch:hover,
.variant-options-grid label.variant-swatch:hover {
  transform: translateY(-4px) scale(1.02);
  box-shadow: 0 6px 18px rgba(0,0,0,0.18);
}

{% comment %} FIM DAS ANIMAÇÕES {% endcomment %}


.product-form__input input[type='radio'] + label.color-swatch,
.product-form__input input[type='radio'] + label.color-swatch:after,
.product-form__input input[type='radio'] + label.color-swatch:before{
        border-radius: 0;
}
.product-form__input input[type='radio'] + label.color-swatch.round,
.product-form__input input[type='radio'] + label.color-swatch.round:after,
.product-form__input input[type='radio'] + label.color-swatch.round:before{
    border-radius: 100%;
  }
.product-form__input input[type='radio'] + label.color-swatch.round-corners,
.product-form__input input[type='radio'] + label.color-swatch.round-corners:after,
.product-form__input input[type='radio'] + label.color-swatch.round-corners:before{
        border-radius: 5px;
  }
  .product-form__input input[type='radio'] + label.color-swatch:before{
    content: "";
    position: absolute;
    top: -1px;
    left: -1px;
    width: calc(100% + 2px);
    height: calc(100% + 2px);
    border: 1px solid var(--Rectangle-43357, #FEF1F6);

    z-index: 0;
  }
  .product-form__input input[type='radio'] + label.color-swatch:after{
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    {%- if settings.dark or swatchType == "variantImage" -%}
      border: none;
    {%- else -%}
     border-radius: 8px;
        border: 1px solid {{settings.color_background_swatch_border}};
        background: {{settings.color_background_swatch}};
    {%- endif -%}
  }
  .product-form__input input[type='radio'] + label.color-swatch:hover:before{
    border: 1px {{settings.color_background_swatch_border}} solid;
  }
  .product-form__input input[type='radio']:checked + label.color-swatch:before{
    background: {{settings.color_background_swatch}};
    border: 1px solid {{settings.color_background_swatch_border}};
  }
  .product-form__input input[type='radio'] + label.color-swatch.variant-swatch{
    background: {{settings.color_background_swatch_suave}};
    {%- if swatchStyle == "portrait" -%}
    height: calc({{swatchSize}}px/ 0.66);
    {%- endif -%}
  }

.add-new{
  display: none !important;
}

.product-form__input input[type='radio'].add-new-class + label.color-swatch {
  border: 3px solid {{settings.color_background_swatch_border}};
  background: {{settings.color_background_swatch}};
}
.variant-options-grid{
    display: grid;
    gap: 16px;
    width: 100%;
}
.variant-structure{
        display: flex;
    justify-content: space-between;
    align-items: center;
    text-align: start;
}
.variant-name{
    font-size: {{settings.tamanho_titulos_main}}px;
    font-style: normal;
    font-weight: 600;
    line-height: 120%; /* 28.8px */
    margin:0px;
    color: {{ settings.color_text_main }};
}
.economy{
    overflow: hidden;
    color:  {{settings.color_text_sub}};
    text-overflow: ellipsis;
    font-size: {{settings.tamanho_titulos_second}}px;
    font-style: normal;
    font-weight: 400;
    line-height: 150%; /* 24px */
}
.value-final-price{
    color: {{settings.color_text_main}};
    font-size: {{settings.tamanho_titulos_main}}px;
    font-style: normal;
    font-weight: 600;
    line-height: 120%; /* 28.8px */
    margin: 0px;
}
.values-info{
    display: grid;
    gap: 6px;
    text-align: end;
}
.price-old-value{
     color: {{settings.color_text_sub}};
    text-align: right;
    font-size: {{settings.tamanho_titulos_second}}px;
    font-style: normal;
    font-weight: 400;
    line-height: 150%; /* 24px */
}
.infos-option{
  display: grid;
    gap: 6px;
}
.badge-option-pdp{
    position: absolute;
    right: 0%;
    top: -12%;
    padding: 4px 6px;
    font-size: 12px;
    border-radius: {{ settings.arredondamento_borda }}px;
}
.custo-beneficio-badge{
  background: {{ settings.color_background_custo_benef }};
  color: {{ settings.color_text_custo_benef }};
}
.em-alta-badge{
   background: {{ settings.color_background_em_alta }};
  color: {{ settings.color_text_em_alta }};
}
.badge-option-frete{
  font-size: 11px;
  padding: 0.2rem 0.4rem;
  border-radius: {{settings.arredondamento_borda}}px;
  font-weight: 600;
  background: {{settings.color_background_custo_benef}};
  color: {{settings.color_text_custo_benef}};
}
@media(max-width: 890px){
  .value-final-price, .variant-name{
    font-size: 18px;
  }
  .price-old-value, .economy{
    font-size: 14px;
  }
}
</style>

{%- if block.settings.picker_type == 'button' -%}
  <div class="variant-options-grid">
{%- endif -%}
{%- for value in option.values -%}
  {%- liquid
    assign option_disabled = true

    for option1_name in variants_option1_arr
      case option.position
        when 1
          if variants_option1_arr[forloop.index0] == value and variants_available_arr[forloop.index0]
            assign option_disabled = false
          endif
        when 2
          if option1_name == product.selected_or_first_available_variant.option1 and variants_option2_arr[forloop.index0] == value and variants_available_arr[forloop.index0]
            assign option_disabled = false
          endif
        when 3
          if option1_name == product.selected_or_first_available_variant.option1 and variants_option2_arr[forloop.index0] == product.selected_or_first_available_variant.option2 and variants_option3_arr[forloop.index0] == value and variants_available_arr[forloop.index0]
            assign option_disabled = false
          endif
      endcase
    endfor
  -%}

  {%- if block.settings.picker_type == 'button' -%}
    <input
      type="radio"
      id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
      name="{{ option.name }}"
      value="{{ value | escape }}"
      form="{{ product_form_id }}"
      {% if option.selected_value == value %}
      class="add-new-class"
  {% endif %}
    >
    {%- if swatchType == "variantImage" -%}
  {%- assign threshold_cents = settings.shipping_free  | remove: '.' | remove: ',' | plus: 0 -%}
          {%- assign optionIndex = option.position | minus: 1 -%}
          {%- assign variant_for_this_swatch = null -%}
          {%- assign variant_image_url = '' -%}
          {%- assign show_free_shipping = false -%}
          {%- assign swatchSizePortrait = swatchSize | times: 2 -%}
          {%- for variant_loop in product.variants -%}
            {%- if variant_loop.options[optionIndex] == value -%}
              {%- assign variant_for_this_swatch = variant_loop -%}
              {%- assign variant_image_url = variant_loop.image | image_url: width: swatchSizePortrait -%}
              {%- if variant_loop.price >= threshold_cents -%}
                {%- assign show_free_shipping = true -%}
              {%- endif -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
    
      <label
      data-{{ option.name }}="{{value}}"
        class="color-swatch variant-swatch {% case swatchStyle %}{% when "round" %}round{% when "square-round-corners" %}round-corners{% endcase %}"
        for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}">
        <div class="variant-structure">
          <div class="infos-option">
            <p class="variant-name">
              {{ value }} 
               {%- if settings.ativar_badge_frete and variant_for_this_swatch.price >= threshold_cents -%}
                 <span class="badge-option-frete frete-gratis-badge">Frete grátis</span>
               {%- endif -%}
            </p>
             {%- if custo_beneficio_index == forloop.index -%}
                <span class="badge-option-pdp custo-beneficio-badge">{{ settings.text_custo_beneficio }}</span>
              {%- endif -%}

              {%- if em_alta_index == forloop.index -%}
                <span class="badge-option-pdp em-alta-badge">{{ settings.text_em_alta }}</span>
              {%- endif -%}
            {% if variant_for_this_swatch.compare_at_price > variant_for_this_swatch.price %}
                {% assign savings = variant_for_this_swatch.compare_at_price | minus: variant_for_this_swatch.price %}
                <span class="economy">Você economiza {{ savings | money }}</span>
            {% endif %}
          </div>
          <div class="values-info">
            <s class="price-old-value">{{ variant_for_this_swatch.compare_at_price | money }}</s>
            <p class="value-final-price">{{ variant_for_this_swatch.price | money }}</p>
          </div>
        </div>
      <span class="visually-hidden">{{ 'products.product.variant_sold_out_or_unavailable' | t }}</span>
            
    </label>
    {%- else -%}
        {%- liquid
        for colorData in swatchColors
            assign colorDataArr = colorData | split:":"
            assign ruleName = colorDataArr[0] | strip
            if value == ruleName
                assign colorCodes = colorDataArr[1] | strip | split :"#"
                assign colorNumber = 0 | plus: colorCodes.size
                break
            endif
        endfor
    -%}
    <label
      data-{{ option.name }}="{{value}}"
      style="
    {%- case colorNumber -%}
        {%- when 2 -%}
            background-color: #{{ colorCodes[1] }}
        {%- when 3 -%}
            background: linear-gradient(135deg, #{{ colorCodes[1] }} 50%, #{{ colorCodes[2] }} 50%);
        {%- when 4 -%}
            background: linear-gradient(to right,#{{ colorCodes[1] }} 33%,#{{ colorCodes[2] }} 33%,#{{ colorCodes[2] }} 66%, #{{ colorCodes[3] }} 66%);
        {%- else -%}
            background-image:url({{ colorCodes[0] | downcase | replace: ' ', '-' | file_img_url }})
        {%- endcase -%}
        ;"class="color-swatch {% case swatchStyle %}{% when "round" %}round{% when "square-round-corners" %}round-corners{% endcase %}"
        for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}">
      <span class="visually-hidden">{{ 'products.product.variant_sold_out_or_unavailable' | t }}</span>
    </label>
    {%- assign colorCodes = "" -%}
    {%- endif -%}
  {%- elsif block.settings.picker_type == 'dropdown' -%}
    <option
      value="{{ value | escape }}"
      {% if option.selected_value == value %}
        selected="selected"
      {% endif %}
    >
      {% if option_disabled -%}
        {{- 'products.product.value_unavailable' | t: option_value: value -}}
      {%- else -%}
        {{- value -}}
      {%- endif %}
    </option>
  {%- endif -%}
  
{%- endfor -%}

{%- if block.settings.picker_type == 'button' -%}
  </div>
{%- endif -%}
<script>
  document.querySelectorAll('input+label[data-{{ option.name | downcase }}]').forEach(el=>{
    el.addEventListener('click',()=>{
      document.querySelector('#selected-{{option.name}}').textContent = " "+el.getAttribute('data-{{ option.name | downcase }}')
    })
  })
</script>