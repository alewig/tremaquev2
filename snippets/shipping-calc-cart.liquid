{%- style -%}
  .shipping-calc-cart__details {
    border-bottom: 1px solid #E5E5E5;
  }
  .shipping-calc-cart {
    margin: 1rem 0;
    border-radius: 8px;
    overflow: hidden;
  }
  .shipping-calc-cart summary {
    list-style: none;
    padding: 0.75rem 0;
    cursor: pointer;
    font-weight: 600;
    font-size: 14px;
    color: #4A4A4A;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    -webkit-tap-highlight-color: transparent;
  }
  .shipping-calc-cart summary::-webkit-details-marker { display: none; }
  .shipping-calc-cart__icon {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    color: #4A4A4A;
  }
  .shipping-calc-cart__icon--minus { display: none; }
  .shipping-calc-cart[open] .shipping-calc-cart__icon--plus { display: none; }
  .shipping-calc-cart[open] .shipping-calc-cart__icon--minus { display: block; }
  .shipping-calc-cart__icon--plus,
  .shipping-calc-cart__icon--minus {
    transition: transform 0.25s ease, opacity 0.2s ease;
  }
  .shipping-calc-cart__panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.35s ease-out;
  }
  .shipping-calc-cart__details[open] .shipping-calc-cart__panel {
    grid-template-rows: 1fr;
  }
  .shipping-calc-cart__panel-inner {
    overflow: hidden;
    min-height: 0;
  }
  .shipping-calc-cart__content {
    padding: 0 0 1rem 0;
    opacity: 0;
    transition: opacity 0.25s ease 0.05s;
  }
  .shipping-calc-cart__details[open] .shipping-calc-cart__content {
    opacity: 1;
  }
  /* Pílula: input + botão unidos (design Figma) */
  .shipping-calc-cart__pill {
    display: flex;
    margin-top: 0.75rem;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.06);
  }
  .shipping-calc-cart__row {
    display: flex;
    width: 100%;
  }
  .shipping-calc-cart__input {
    flex: 1;
    min-width: 0;
    padding: 0.75rem 1rem;
    border: 1px solid #E5E5E5;
    border-right: none;
    border-radius: 8px 0 0 8px;
    font-size: 14px;
    background: #fff;
    color: #1a1a1a;
  }
  .shipping-calc-cart__input::placeholder {
    color: #9E9E9E;
  }
  .shipping-calc-cart__input:focus {
    outline: none;
    border-color: #E5E5E5;
    box-shadow: none;
  }
  .shipping-calc-cart__btn {
    padding: 0.75rem 1.25rem;
    border: none;
    border-radius: 0 8px 8px 0;
    font-weight: 600;
    font-size: 14px;
    letter-spacing: 0.02em;
    cursor: pointer;
    background: #B10326;
    color: #fff;
    white-space: nowrap;
  }
  .shipping-calc-cart__btn:hover {
    opacity: 0.92;
  }
  .shipping-calc-cart__btn:focus-visible {
    outline: 2px solid #B10326;
    outline-offset: 2px;
  }
  .shipping-calc-cart__btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }
  .shipping-calc-cart__opcoes {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid #E5E5E5;
    min-width: 0;
  }
  .shipping-calc-cart__opcoes-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 10px 0;
    font-size: 14px;
    line-height: 1.4;
    color: #1a1a1a;
    min-width: 0;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    border: none;
    background: none;
    width: 100%;
    text-align: left;
    position: relative;
  }
  .shipping-calc-cart__opcoes-item:hover {
    opacity: 0.9;
  }
  .shipping-calc-cart__opcoes-item-radio {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    border: 2px solid #9E9E9E;
    border-radius: 50%;
    background: #fff;
    margin-top: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s, background 0.2s;
  }
  .shipping-calc-cart__opcoes-item-radio::after {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #B10326;
    transform: scale(0);
    transition: transform 0.15s ease;
  }
  .shipping-calc-cart__opcoes-item input:checked + .shipping-calc-cart__opcoes-item-radio {
    border-color: #B10326;
  }
  .shipping-calc-cart__opcoes-item input:checked + .shipping-calc-cart__opcoes-item-radio::after {
    transform: scale(1);
  }
  .shipping-calc-cart__opcoes-item input {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }
  .shipping-calc-cart__opcoes-item-text {
    flex: 1;
    min-width: 0;
  }
  .shipping-calc-cart__opcoes-item-text strong {
    display: block;
    font-weight: 600;
    color: #1a1a1a;
  }
  .shipping-calc-cart__opcoes-item-prazo {
    display: block;
    font-size: 12px;
    color: #6d6d6d;
    margin-top: 2px;
  }
  .shipping-calc-cart__opcoes-item-price {
    flex-shrink: 0;
    font-weight: 600;
    color: #1a1a1a;
  }
  .shipping-calc-cart__opcoes-item + .shipping-calc-cart__opcoes-item {
    border-top: 1px solid rgba(0,0,0,0.06);
  }
  .shipping-calc-cart__opcoes-empty,
  .shipping-calc-cart__opcoes-loading {
    font-size: 14px;
    color: #6d6d6d;
    margin: 0;
  }
  .shipping-calc-cart__opcoes-loading {
    display: flex;
    align-items: center;
    gap: 8px;
  }
{%- endstyle -%}

<div class="shipping-calc-cart">
  <details class="shipping-calc-cart__details" open>
    <summary>
      <span>Calcule seu frete</span>
      <span class="shipping-calc-cart__icon shipping-calc-cart__icon--plus" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" focusable="false"><path d="M4 12H20M12 4V20" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </span>
      <span class="shipping-calc-cart__icon shipping-calc-cart__icon--minus" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" focusable="false"><path d="M6 12L18 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </span>
    </summary>
    <div class="shipping-calc-cart__panel">
      <div class="shipping-calc-cart__panel-inner">
        <div class="shipping-calc-cart__content">
          <div class="shipping-calc-cart__pill">
            <div class="shipping-calc-cart__row">
              <input
                type="text"
                id="shipping-calc-cart-cep"
                class="shipping-calc-cart__input"
                placeholder="00000-000"
                inputmode="numeric"
                pattern="[0-9]{5}-?[0-9]{3}"
                maxlength="9"
                autocomplete="postal-code"
                data-cep-raw
              >
              <button type="button" id="shipping-calc-cart-button" class="shipping-calc-cart__btn">
                CALCULAR
              </button>
            </div>
          </div>
          <div id="shipping-calc-cart-opcoes" class="shipping-calc-cart__opcoes" aria-live="polite" hidden></div>
        </div>
      </div>
    </div>
  </details>
</div>

<script type="application/json" id="shipping-calc-cart-data">
{
  "shipmentInvoiceValueCents": {{ cart.total_price | default: 0 }},
  "items": [
    {%- for item in cart.items -%}
      {%- assign w_grams = item.variant.weight -%}
      {%- if w_grams == nil or w_grams == 0 -%}{%- assign w_grams = 300 -%}{%- endif -%}
      {%- assign num_altura = item.properties._frenet_altura | default: item.product.metafields.frenet.altura.value | split: ' ' | first | replace: ',', '.' -%}
      {%- assign num_comprimento = item.properties._frenet_comprimento | default: item.product.metafields.frenet.comprimento.value | split: ' ' | first | replace: ',', '.' -%}
      {%- assign num_largura = item.properties._frenet_largura | default: item.product.metafields.frenet.largura.value | split: ' ' | first | replace: ',', '.' -%}
      {%- if num_altura == blank -%}{%- assign num_altura = item.variant.metafields.frenet.altura.value | split: ' ' | first | replace: ',', '.' -%}{%- endif -%}
      {%- if num_comprimento == blank -%}{%- assign num_comprimento = item.variant.metafields.frenet.comprimento.value | split: ' ' | first | replace: ',', '.' -%}{%- endif -%}
      {%- if num_largura == blank -%}{%- assign num_largura = item.variant.metafields.frenet.largura.value | split: ' ' | first | replace: ',', '.' -%}{%- endif -%}
      {%- assign item_h = num_altura | default: 21 -%}
      {%- assign item_l = num_comprimento | default: 7 -%}
      {%- assign item_w = num_largura | default: 14 -%}
      {"sku":{{ item.variant.sku | json }},"height":{{ item_h | json }},"length":{{ item_l | json }},"width":{{ item_w | json }},"weightGrams":{{ w_grams }},"quantity":{{ item.quantity }}}{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ]
}
</script>

<script>
  (function () {
    var productDimensionsCache = {};

    function maskCep(value) {
      var digits = value.replace(/\D/g, '').slice(0, 8);
      if (digits.length <= 5) return digits;
      return digits.slice(0, 5) + '-' + digits.slice(5);
    }

    function getCartShippingData() {
      var el = document.getElementById('shipping-calc-cart-data');
      if (!el || !el.textContent) return null;
      try { return JSON.parse(el.textContent); } catch (e) { return null; }
    }

    document.addEventListener('input', function (e) {
      if (e.target.id !== 'shipping-calc-cart-cep') return;
      var input = e.target;
      var start = input.selectionStart;
      var oldLen = input.value.length;
      input.value = maskCep(input.value);
      input.setAttribute('data-cep-raw', input.value.replace(/\D/g, ''));
      var newLen = input.value.length;
      var newStart = Math.max(0, start + (newLen - oldLen));
      input.setSelectionRange(newStart, newStart);
    });
    document.addEventListener('paste', function (e) {
      if (e.target.id !== 'shipping-calc-cart-cep') return;
      e.preventDefault();
      var input = e.target;
      var pasted = (e.clipboardData || window.clipboardData).getData('text');
      input.value = maskCep(pasted);
      input.setAttribute('data-cep-raw', input.value.replace(/\D/g, ''));
    }, true);

    function formatCEP(cep) {
      var cepLimpo = String(cep).replace(/\D/g, '');
      if (cepLimpo.length < 8) return cepLimpo.padEnd(8, '0');
      return cepLimpo.substring(0, 8);
    }

    function formatWeight(weightGrams) {
      return parseFloat(((Number(weightGrams) || 0) / 1000).toFixed(3));
    }

    function formatDimension(value, fallback) {
      var normalized = String(value == null ? '' : value).replace(',', '.');
      var parsed = parseFloat(normalized);
      return Number.isFinite(parsed) ? parsed : fallback;
    }

    function normalizeDimensionValue(value) {
      if (value == null || value === '') return '';
      return String(value).replace(',', '.');
    }

    async function fetchCartJson() {
      var response = await fetch('/cart.js', { credentials: 'same-origin' });
      if (!response.ok) throw new Error('cart.js request failed');
      return response.json();
    }

    async function fetchProductDimensions(itemUrl) {
      if (!itemUrl) return null;
      if (productDimensionsCache[itemUrl]) return productDimensionsCache[itemUrl];

      var request = fetch(itemUrl, { credentials: 'same-origin' })
        .then(function (response) {
          if (!response.ok) throw new Error('product page request failed');
          return response.text();
        })
        .then(function (html) {
          var doc = new DOMParser().parseFromString(html, 'text/html');

          function readInput(name) {
            var selector = 'input[name="properties[' + name + ']"]';
            var input = doc.querySelector(selector);
            return input ? normalizeDimensionValue(input.value) : '';
          }

          return {
            height: readInput('_frenet_altura'),
            length: readInput('_frenet_comprimento'),
            width: readInput('_frenet_largura')
          };
        })
        .catch(function () {
          return null;
        });

      productDimensionsCache[itemUrl] = request;
      return request;
    }

    async function buildLiveCartShippingData() {
      var cart = await fetchCartJson();
      var items = await Promise.all((cart.items || []).map(async function(item) {
        var properties = item.properties || {};
        var height = normalizeDimensionValue(properties._frenet_altura);
        var length = normalizeDimensionValue(properties._frenet_comprimento);
        var width = normalizeDimensionValue(properties._frenet_largura);

        if (!height || !length || !width) {
          var fallbackDimensions = await fetchProductDimensions(item.url);
          if (fallbackDimensions) {
            height = height || fallbackDimensions.height;
            length = length || fallbackDimensions.length;
            width = width || fallbackDimensions.width;
          }
        }

        return {
          sku: item.sku || '',
          height: height || '21',
          length: length || '7',
          width: width || '14',
          weightGrams: item.grams || 300,
          quantity: item.quantity || 1
        };
      }));

      return {
        shipmentInvoiceValueCents: cart.total_price || 0,
        items: items
      };
    }

    function toQueryString(obj, prefix) {
      var str = [];
      for (var p in obj) {
        if (Object.prototype.hasOwnProperty.call(obj, p)) {
          var k = prefix ? prefix + '[' + p + ']' : p;
          var v = obj[p];
          str.push(
            v !== null && typeof v === 'object'
              ? toQueryString(v, k)
              : encodeURIComponent(k) + '=' + encodeURIComponent(v)
          );
        }
      }
      return str.join('&');
    }

    function formatMoneyCents(cents, symbol) {
      symbol = symbol || 'R$';
      var intPart = Math.floor(cents / 100);
      var centPart = Math.abs(cents % 100);
      var intStr = intPart.toString().replace(/\B(?=(\d{3})+(?!\d))/g, '.');
      return symbol + ' ' + intStr + ',' + String(centPart).padStart(2, '0');
    }

    function updateCartFooterTotal() {
      var footer = document.getElementById('main-cart-footer');
      var totalsDiv = footer && footer.querySelector('.totals');
      if (!totalsDiv) return;
      var totalValueEl = document.getElementById('cart-footer-estimated-total') || totalsDiv.querySelector('.totals__total-value');
      if (!totalValueEl) return;
      var cartTotalCents = parseInt(totalsDiv.getAttribute('data-cart-total-cents') || '0', 10);
      var symbol = totalsDiv.getAttribute('data-currency-symbol') || 'R$';
      var opcoesEl = document.getElementById('shipping-calc-cart-opcoes');
      var selectedPrice = opcoesEl ? opcoesEl.getAttribute('data-selected-price') : null;
      var selectedName = opcoesEl ? (opcoesEl.getAttribute('data-selected-name') || '') : '';
      var shippingCents = (selectedPrice !== null && selectedPrice !== '') ? Math.round(parseFloat(selectedPrice) * 100) : 0;
      var totalCents = cartTotalCents + shippingCents;
      totalValueEl.textContent = formatMoneyCents(totalCents, symbol);

      // Update shipping summary line
      var shippingRow = document.getElementById('cart-shipping-total-row');
      var shippingPriceEl = document.getElementById('cart-shipping-total-value');
      var shippingNameEl = document.getElementById('cart-shipping-carrier-name');
      if (shippingRow) {
        if (selectedPrice !== null && selectedPrice !== '') {
          if (shippingNameEl) shippingNameEl.textContent = selectedName || 'Entrega';
          if (shippingPriceEl) shippingPriceEl.textContent = shippingCents > 0 ? formatMoneyCents(shippingCents, symbol) : 'Grátis';
          shippingRow.style.display = '';
        } else {
          shippingRow.style.display = 'none';
        }
      }

      var pixValueEl = document.getElementById('totals-pix-value');
      var parcelasValueEl = document.getElementById('totals-parcelas-value');
      var pixDiscountPct = parseInt(totalsDiv.getAttribute('data-pix-discount-pct') || '0', 10);
      var parcelas = parseInt(totalsDiv.getAttribute('data-parcelas') || '3', 10);
      var pixEnabled = totalsDiv.getAttribute('data-pix-enabled') === 'true';

      if (pixValueEl && pixEnabled && pixDiscountPct > 0) {
        var discountMultiplier = pixDiscountPct * 0.01;
        var pixPriceCents = Math.round(totalCents * (1 - discountMultiplier));
        pixValueEl.textContent = formatMoneyCents(pixPriceCents, symbol);
      }
      if (parcelasValueEl && parcelas > 0) {
        var installmentCents = Math.floor(totalCents / parcelas);
        parcelasValueEl.textContent = formatMoneyCents(installmentCents, symbol);
      }
    }

    document.addEventListener('click', async function (e) {
      var btn = e.target.id === 'shipping-calc-cart-button' ? e.target : (e.target.closest && e.target.closest('#shipping-calc-cart-button'));
      if (!btn) return;
      e.preventDefault();
      var input = document.getElementById('shipping-calc-cart-cep');
      var opcoesEl = document.getElementById('shipping-calc-cart-opcoes');
      if (!input || !opcoesEl) return;

      var raw = input.getAttribute('data-cep-raw') || input.value.replace(/\D/g, '');
      if (raw.length < 8) {
        opcoesEl.innerHTML = '<p class="shipping-calc-cart__opcoes-empty">Digite um CEP válido (8 dígitos).</p>';
        opcoesEl.hidden = false;
        return;
      }

      var cepFormatado = formatCEP(raw);
      opcoesEl.innerHTML = '<p class="shipping-calc-cart__opcoes-loading">Calculando frete...</p>';
      opcoesEl.hidden = false;
      btn.disabled = true;

      try {
        var cartShippingData = await buildLiveCartShippingData();
        if ((!cartShippingData.items || cartShippingData.items.length === 0) || cartShippingData.shipmentInvoiceValueCents === 0) {
          var fallbackCartShippingData = getCartShippingData();
          cartShippingData = fallbackCartShippingData || cartShippingData;
        }

        if (!cartShippingData.items || cartShippingData.items.length === 0 || cartShippingData.shipmentInvoiceValueCents === 0) {
          opcoesEl.innerHTML = '<p class="shipping-calc-cart__opcoes-empty">Adicione produtos ao carrinho para calcular o frete.</p>';
          return;
        }

        var shipmentInvoiceValue = cartShippingData.shipmentInvoiceValueCents / 100;
        var shippingItemArray = cartShippingData.items.map(function(item) {
          return {
            Height: formatDimension(item.height, 21),
            Length: formatDimension(item.length, 7),
            Quantity: item.quantity || 1,
            Weight: formatWeight(item.weightGrams || 300),
            Width: formatDimension(item.width, 14),
            SKU: item.sku || '',
            Category: 'Produto'
          };
        });

        var params = {
          SellerCEP: '86065270',
          RecipientCEP: cepFormatado,
          ShipmentInvoiceValue: shipmentInvoiceValue,
          ShippingItemArray: JSON.stringify(shippingItemArray),
          RecipientCountry: 'Brasil'
        };

        var token = '622110E8R81CER4B0DR97CBRF44173A82224';
        var shippingUrl = 'https://calc-wig.vercel.app/shipping/quote?' + toQueryString(params) + '&token=' + token;

        fetch(shippingUrl)
          .then(function (res) { return res.json(); })
          .then(function (data) {
            if (data && data.ShippingSevicesArray && data.ShippingSevicesArray.length > 0) {
              var valid = data.ShippingSevicesArray.filter(function (item) {
                return item.ShippingPrice != null && item.DeliveryTime != null;
              });
              if (valid.length > 0) {
                opcoesEl.innerHTML = valid.map(function (item, index) {
                  var price = parseFloat(item.ShippingPrice);
                  var prazo = item.DeliveryTime + ' dias úteis';
                  var nome = item.Carrier || item.ServiceDescription || item.CarrierName || 'Forma de Entrega';
                  var priceStr = 'R$ ' + price.toFixed(2).replace('.', ',');
                  var value = index;
                  return '<label class="shipping-calc-cart__opcoes-item">' +
                    '<input type="radio" name="shipping-calc-cart-option" value="' + value + '" data-price="' + price + '" data-name="' + nome.replace(/"/g, '&quot;') + '" data-prazo="' + prazo.replace(/"/g, '&quot;') + '">' +
                    '<span class="shipping-calc-cart__opcoes-item-radio" aria-hidden="true"></span>' +
                    '<span class="shipping-calc-cart__opcoes-item-text">' +
                      '<strong>' + nome + '</strong>' +
                      '<span class="shipping-calc-cart__opcoes-item-prazo">' + prazo + '</span>' +
                    '</span>' +
                    '<span class="shipping-calc-cart__opcoes-item-price">' + priceStr + '</span>' +
                  '</label>';
                }).join('');
                opcoesEl.setAttribute('role', 'radiogroup');
                opcoesEl.setAttribute('aria-label', 'Opções de frete');
                var radios = opcoesEl.querySelectorAll('input[name="shipping-calc-cart-option"]');
                function updateSelected(forcedRadio) {
                  var r = forcedRadio || opcoesEl.querySelector('input[name="shipping-calc-cart-option"]:checked');
                  if (r) {
                    opcoesEl.dataset.selectedPrice = r.dataset.price || '';
                    opcoesEl.dataset.selectedName = r.dataset.name || '';
                    opcoesEl.dataset.selectedPrazo = r.dataset.prazo || '';
                    var footer = document.getElementById('main-cart-footer');
                    var totalsDiv = footer && footer.querySelector('.totals');
                    var totalValueEl = document.getElementById('cart-footer-estimated-total');
                    if (totalsDiv && totalValueEl) {
                      var cartTotalCents = parseInt(totalsDiv.getAttribute('data-cart-total-cents') || '0', 10);
                      var symbol = totalsDiv.getAttribute('data-currency-symbol') || 'R$';
                      var shippingCents = Math.round(parseFloat(r.dataset.price || '0') * 100);
                      var totalCents = cartTotalCents + shippingCents;
                      totalValueEl.textContent = formatMoneyCents(totalCents, symbol);
                      var pixDiscountPct = parseInt(totalsDiv.getAttribute('data-pix-discount-pct') || '0', 10);
                      var parcelas = parseInt(totalsDiv.getAttribute('data-parcelas') || '3', 10);
                      var pixValueEl = document.getElementById('totals-pix-value');
                      var parcelasValueEl = document.getElementById('totals-parcelas-value');
                      if (pixValueEl && pixDiscountPct > 0) {
                        pixValueEl.textContent = formatMoneyCents(Math.round(totalCents * (1 - pixDiscountPct * 0.01)), symbol);
                      }
                      if (parcelasValueEl && parcelas > 0) {
                        parcelasValueEl.textContent = formatMoneyCents(Math.floor(totalCents / parcelas), symbol);
                      }
                    }
                  }
                  updateCartFooterTotal();
                }
                radios.forEach(function (r) { r.addEventListener('change', updateSelected); });
              } else {
                opcoesEl.innerHTML = '<p class="shipping-calc-cart__opcoes-empty">Nenhuma opção de frete encontrada para este CEP.</p>';
              }
            } else {
              opcoesEl.innerHTML = '<p class="shipping-calc-cart__opcoes-empty">Nenhuma opção de frete encontrada para este CEP.</p>';
            }
          })
          .catch(function () {
            opcoesEl.innerHTML = '<p class="shipping-calc-cart__opcoes-empty">Não foi possível calcular o frete. Tente novamente.</p>';
          })
          .finally(function () {
            btn.disabled = false;
          });
      } catch (error) {
        opcoesEl.innerHTML = '<p class="shipping-calc-cart__opcoes-empty">Não foi possível calcular o frete. Tente novamente.</p>';
        btn.disabled = false;
      }
    });

    // Atualiza o total, pix e parcelamento quando o usuário troca a opção de frete
    document.addEventListener('change', function(e) {
      if (!e.target || e.target.name !== 'shipping-calc-cart-option') return;
      var footer = document.getElementById('main-cart-footer');
      var totalsDiv = footer && footer.querySelector('.totals');
      if (!totalsDiv) return;
      var totalValueEl = document.getElementById('cart-footer-estimated-total');
      if (!totalValueEl) return;
      var cartTotalCents = parseInt(totalsDiv.getAttribute('data-cart-total-cents') || '0', 10);
      var symbol = totalsDiv.getAttribute('data-currency-symbol') || 'R$';
      var shippingCents = e.target.checked ? Math.round(parseFloat(e.target.dataset.price || '0') * 100) : 0;
      var totalCents = cartTotalCents + shippingCents;
      totalValueEl.textContent = formatMoneyCents(totalCents, symbol);

      var pixDiscountPct = parseInt(totalsDiv.getAttribute('data-pix-discount-pct') || '0', 10);
      var parcelas = parseInt(totalsDiv.getAttribute('data-parcelas') || '3', 10);
      var pixValueEl = document.getElementById('totals-pix-value');
      var parcelasValueEl = document.getElementById('totals-parcelas-value');
      if (pixValueEl && pixDiscountPct > 0) {
        pixValueEl.textContent = formatMoneyCents(Math.round(totalCents * (1 - pixDiscountPct * 0.01)), symbol);
      }
      if (parcelasValueEl && parcelas > 0) {
        parcelasValueEl.textContent = formatMoneyCents(Math.floor(totalCents / parcelas), symbol);
      }
    });

  })();
</script>
