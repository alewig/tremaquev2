{%- liquid
  assign share_product = product
  if share_product == blank
    assign share_product = card_product
  endif

  if share_product != blank
    assign product_title = share_product.title | escape
    assign product_price = share_product.price | money
    assign product_url = shop.url | append: share_product.url
    assign share_text = product_title | append: ' - ' | append: product_price
  endif
-%}

{%- assign fav_product_handle = share_product.handle | default: '' -%}
<div class="tools-container">
    <button
      type="button"
      class="fav-icon icon-tools {% if fav_product_handle == blank %}fav-icon--disabled{% endif %}"
      data-product-handle="{{ fav_product_handle | escape }}"
      aria-label="{% if fav_product_handle != blank %}Adicionar aos favoritos{% else %}Favoritos{% endif %}"
      {% if fav_product_handle == blank %}disabled{% endif %}
    >
        <span class="fav-icon-outline fav-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <path fill-rule="evenodd" clip-rule="evenodd" d="M12 6.00019C10.2006 3.90317 7.19377 3.2551 4.93923 5.17534C2.68468 7.09558 2.36727 10.3061 4.13778 12.5772C5.60984 14.4654 10.0648 18.4479 11.5249 19.7369C11.6882 19.8811 11.7699 19.9532 11.8652 19.9815C11.9483 20.0062 12.0393 20.0062 12.1225 19.9815C12.2178 19.9532 12.2994 19.8811 12.4628 19.7369C13.9229 18.4479 18.3778 14.4654 19.8499 12.5772C21.6204 10.3061 21.3417 7.07538 19.0484 5.17534C16.7551 3.2753 13.7994 3.90317 12 6.00019Z" stroke="#5D5D5D" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path> </g></svg>
        </span>
        <span class="fav-icon-filled fav-icon" aria-hidden="true" hidden>
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <path fill-rule="evenodd" clip-rule="evenodd" d="M12 6.00019C10.2006 3.90317 7.19377 3.2551 4.93923 5.17534C2.68468 7.09558 2.36727 10.3061 4.13778 12.5772C5.60984 14.4654 10.0648 18.4479 11.5249 19.7369C11.6882 19.8811 11.7699 19.9532 11.8652 19.9815C11.9483 20.0062 12.0393 20.0062 12.1225 19.9815C12.2178 19.9532 12.2994 19.8811 12.4628 19.7369C13.9229 18.4479 18.3778 14.4654 19.8499 12.5772C21.6204 10.3061 21.3417 7.07538 19.0484 5.17534C16.7551 3.2753 13.7994 3.90317 12 6.00019Z" stroke="#F62D13" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path> </g></svg>
        </span>
    </button>
    {%- if share_product != blank -%}
      <button 
        class="share-icon icon-tools" 
        type="button"
        data-share-url="{{ product_url }}"
        data-share-title="{{ product_title }}"
        data-share-text="{{ share_text }}"
        aria-label="Compartilhar produto"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 30 30" fill="none">
            <path d="M10.7375 16.8875L19.275 21.8625M19.2625 8.1375L10.7375 13.1125M26.25 6.25C26.25 8.32107 24.5711 10 22.5 10C20.4289 10 18.75 8.32107 18.75 6.25C18.75 4.17893 20.4289 2.5 22.5 2.5C24.5711 2.5 26.25 4.17893 26.25 6.25ZM11.25 15C11.25 17.0711 9.57107 18.75 7.5 18.75C5.42893 18.75 3.75 17.0711 3.75 15C3.75 12.9289 5.42893 11.25 7.5 11.25C9.57107 11.25 11.25 12.9289 11.25 15ZM26.25 23.75C26.25 25.8211 24.5711 27.5 22.5 27.5C20.4289 27.5 18.75 25.8211 18.75 23.75C18.75 21.6789 20.4289 20 22.5 20C24.5711 20 26.25 21.6789 26.25 23.75Z" stroke="#5D5D5D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    {%- endif -%}
</div>

<style>
  .fav-icon-filled svg {
    fill: #F62D13;
  }
   .fav-icon svg {
    width: 30px;
    height: 30px;
  }
    .icon-tools{
        width: 30px;
        height: 30px;
    }
    .tools-container{
        display: flex;
        align-items: center;
        gap: 16px;
    }
    .share-icon {
        background: none;
        border: none;
        padding: 0;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: opacity 0.3s ease;
    }
    .share-icon:hover {
        opacity: 0.7;
    }
    .share-icon svg {
        pointer-events: none;
    }
    .fav-icon {
        background: none;
        border: none;
        padding: 0;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: opacity 0.3s ease;
    }
    .fav-icon:hover:not(:disabled) {
        opacity: 0.8;
    }
    .fav-icon:disabled,
    .fav-icon.fav-icon--disabled {
        cursor: default;
        opacity: 0.6;
    }
    .fav-icon .fav-icon-outline,
    .fav-icon .fav-icon-filled {
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .fav-icon .fav-icon-filled[hidden] {
        display: none !important;
    }
    .fav-icon.is-favorited .fav-icon-outline {
        display: none !important;
    }
    .fav-icon.is-favorited .fav-icon-filled {
        display: flex !important;
    }
</style>

<script>
  (function () {
    var FAV_STORAGE_KEY = 'tremaque_favoritos';

    function getFavoritos() {
      try {
        var raw = localStorage.getItem(FAV_STORAGE_KEY);
        return raw ? JSON.parse(raw) : [];
      } catch (e) {
        return [];
      }
    }

    function setFavoritos(arr) {
      try {
        localStorage.setItem(FAV_STORAGE_KEY, JSON.stringify(arr));
        return true;
      } catch (e) {
        return false;
      }
    }

    function syncFavIcon(btn) {
      var handle = btn && btn.getAttribute('data-product-handle');
      if (!handle) return;
      var list = getFavoritos();
      var isFav = list.indexOf(handle) !== -1;
      btn.classList.toggle('is-favorited', isFav);
      var filled = btn.querySelector('.fav-icon-filled');
      if (filled) {
        if (isFav) filled.removeAttribute('hidden');
        else filled.setAttribute('hidden', '');
      }
    }

    document.addEventListener('DOMContentLoaded', function() {
      var favButtons = document.querySelectorAll('.fav-icon[data-product-handle]');
      favButtons.forEach(function(btn) {
        syncFavIcon(btn);
        btn.addEventListener('click', function() {
          var handle = this.getAttribute('data-product-handle');
          if (!handle) return;
          var list = getFavoritos();
          var i = list.indexOf(handle);
          if (i === -1) list.push(handle);
          else list.splice(i, 1);
          setFavoritos(list);
          syncFavIcon(this);
          window.dispatchEvent(new CustomEvent('tremaque-favoritos-changed', { detail: { list: list } }));
        });
      });
    });

    window.TremaqueFavoritos = {
      get: getFavoritos,
      set: setFavoritos,
      key: FAV_STORAGE_KEY
    };
  })();
</script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const shareButtons = document.querySelectorAll('.share-icon');
    
    shareButtons.forEach(button => {
      button.addEventListener('click', async function() {
        const url = this.dataset.shareUrl;
        const title = this.dataset.shareTitle;
        const text = this.dataset.shareText;
        
        // Verifica se o navegador suporta Web Share API
        if (navigator.share) {
          try {
            await navigator.share({
              title: title,
              text: text,
              url: url
            });
          } catch (err) {
            // Usuário cancelou ou erro ao compartilhar
            if (err.name !== 'AbortError') {
              console.error('Erro ao compartilhar:', err);
              copyToClipboard(url, text);
            }
          }
        } else {
          // Fallback: copia para clipboard
          copyToClipboard(url, text);
        }
      });
    });
    
    function copyToClipboard(url, text) {
      const shareContent = text + '\n' + url;
      
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(shareContent).then(() => {
          showCopyFeedback('Link copiado!');
        }).catch(() => {
          fallbackCopy(shareContent);
        });
      } else {
        fallbackCopy(shareContent);
      }
    }
    
    function fallbackCopy(text) {
      const textArea = document.createElement('textarea');
      textArea.value = text;
      textArea.style.position = 'fixed';
      textArea.style.left = '-999999px';
      textArea.style.top = '-999999px';
      document.body.appendChild(textArea);
      textArea.focus();
      textArea.select();
      
      try {
        document.execCommand('copy');
        showCopyFeedback('Link copiado!');
      } catch (err) {
        showCopyFeedback('Erro ao copiar');
      }
      
      document.body.removeChild(textArea);
    }
    
    function showCopyFeedback(message) {
      // Cria tooltip temporário
      const tooltip = document.createElement('div');
      tooltip.textContent = message;
      tooltip.style.cssText = `
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background-color: rgba(0, 0, 0, 0.8);
        color: white;
        padding: 12px 24px;
        border-radius: 8px;
        z-index: 10000;
        font-size: 14px;
      `;
      
      document.body.appendChild(tooltip);
      
      setTimeout(() => {
        tooltip.style.opacity = '0';
        tooltip.style.transition = 'opacity 0.3s ease';
        setTimeout(() => {
          document.body.removeChild(tooltip);
        }, 300);
      }, 2000);
    }
  });
</script>